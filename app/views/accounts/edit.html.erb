<% content_for :title, "Account" %>

<%= render layout: "accounts/layout", locals: { section_title: "Profile" } do %>
  <%= form_with model: @user, url: account_path, method: :patch, class: "space-y-4" do |f| %>
    <%= render "shared/form_errors", resource: @user %>

    <div class="flex items-center gap-4">
      <%= render "shared/user_avatar", user: @user, size: :lg %>
      <div class="space-y-2">
        <%= f.file_field :avatar, accept: "image/png,image/jpeg,image/webp", class: "file-input-dark block w-full text-sm" %>
        <% if @user.avatar.attached? %>
          <label class="flex items-center gap-2 text-sm text-muted">
            <%= check_box_tag "user[remove_avatar]", "1", false, class: "rounded border-border-default" %>
            Remove photo
          </label>
        <% end %>
      </div>
    </div>

    <div>
      <%= f.label :preferred_name, "Preferred name", class: "block text-sm font-medium text-muted" %>
      <%= f.text_field :preferred_name, class: "input-dark", placeholder: "How you'd like to be addressed" %>
    </div>

    <div class="rounded-md border border-border-default bg-elevated p-3 text-sm">
      <p class="text-muted">Legal name</p>
      <p class="font-medium text-primary"><%= @user.full_name %></p>
      <p class="mt-2 text-muted">Email</p>
      <p class="font-medium text-primary"><%= @user.email %></p>
    </div>

    <%= f.submit "Save profile", class: button_classes(:primary), data: { turbo_submits_with: "Saving…" } %>
  <% end %>
<% end %>
