<% content_for :title, "Account" %>

<%= render layout: "accounts/layout", locals: { section_title: "Profile" } do %>
  <%= form_with model: @user, url: account_path, method: :patch, class: "space-y-4" do |f| %>
    <%= render "shared/form_errors", resource: @user %>

    <div class="flex items-center gap-4">
      <%= render "shared/user_avatar", user: @user, size: :lg %>
      <div class="space-y-2">
        <%= f.file_field :avatar, accept: "image/png,image/jpeg,image/webp", class: form_file_input_class %>
        <% if @user.avatar.attached? %>
          <label class="flex items-center gap-2 text-sm text-slate-500 dark:text-slate-400">
            <%= check_box_tag "user[remove_avatar]", "1", false, class: "rounded border-slate-200 dark:border-slate-700" %>
            Remove photo
          </label>
        <% end %>
      </div>
    </div>

    <div>
      <%= f.label :preferred_name, "Preferred name", class: "block text-sm font-medium text-slate-500 dark:text-slate-400" %>
      <%= f.text_field :preferred_name, class: form_input_class, placeholder: "How you'd like to be addressed" %>
    </div>

    <div class="rounded-md border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-700 p-3 text-sm">
      <p class="text-slate-500 dark:text-slate-400">Legal name</p>
      <p class="font-medium text-slate-900 dark:text-slate-100"><%= @user.full_name %></p>
      <p class="mt-2 text-slate-500 dark:text-slate-400">Email</p>
      <p class="font-medium text-slate-900 dark:text-slate-100"><%= @user.email %></p>
    </div>

    <%= f.submit "Save profile", class: button_classes(:primary), data: { turbo_submits_with: "Saving…" } %>
  <% end %>

  <div class="mt-8 border-t border-slate-200 pt-8 dark:border-slate-700">
    <h3 class="text-sm font-semibold text-slate-900 dark:text-slate-100">Appearance</h3>
    <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">Choose how LandIQrd looks on this device.</p>
    <div class="mt-4 flex flex-wrap gap-2">
      <button type="button" data-theme-target="modeButton" data-theme-mode-param="light" data-action="theme#setMode" class="<%= theme_appearance_mode_button_class %>">Light</button>
      <button type="button" data-theme-target="modeButton" data-theme-mode-param="dark" data-action="theme#setMode" class="<%= theme_appearance_mode_button_class %>">Dark</button>
      <button type="button" data-theme-target="modeButton" data-theme-mode-param="system" data-action="theme#setMode" class="<%= theme_appearance_mode_button_class %>">System</button>
    </div>
  </div>
<% end %>
