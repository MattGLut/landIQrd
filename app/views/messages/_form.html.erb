<%= form_with model: [ conversation, message ], class: "space-y-3 rounded-lg border border-border-default bg-surface p-4" do |f| %>
  <%= render "shared/form_errors", resource: message %>
  <%= f.text_area :body, rows: 3, placeholder: "Write a message...", class: "input-dark" %>
  <div class="flex items-center justify-between">
    <%= f.file_field :files, multiple: true, class: "file-input-dark" %>
    <%= f.submit "Send", class: button_classes(:primary), data: { turbo_submits_with: "Sending…" } %>
  </div>
<% end %>
