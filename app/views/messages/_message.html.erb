<div id="<%= dom_id(message) %>" class="rounded-lg bg-gray-50 p-3">
  <div class="flex items-center justify-between">
    <p class="text-sm font-medium text-gray-900"><%= message.author.display_name %></p>
    <p class="text-xs text-gray-400"><%= message.created_at.to_fs(:short) %></p>
  </div>
  <% if message.body.present? %>
    <p class="mt-1 whitespace-pre-line text-sm text-gray-700"><%= message.body %></p>
  <% end %>
  <% if message.files.attached? %>
    <ul class="mt-2 space-y-1">
      <% message.files.each do |file| %>
        <li>
          <%= link_to file.filename, rails_blob_path(file, disposition: "attachment"), class: "text-sm text-indigo-600 hover:text-indigo-500" %>
        </li>
      <% end %>
    </ul>
  <% end %>
</div>
