<div id="<%= dom_id(message) %>" class="rounded-lg bg-elevated p-3">
  <div class="flex items-center justify-between gap-3">
    <div class="flex items-center gap-2">
      <%= render "shared/user_avatar", user: message.author, size: :sm %>
      <p class="text-sm font-medium text-primary"><%= message.author.display_name %></p>
    </div>
    <p class="text-xs text-muted"><%= message.created_at.to_fs(:short) %></p>
  </div>
  <% if message.body.present? %>
    <p class="mt-1 whitespace-pre-line text-sm text-primary"><%= message.body %></p>
  <% end %>
  <% if message.files.attached? %>
    <ul class="mt-2 space-y-1">
      <% message.files.each do |file| %>
        <li>
          <%= link_to file.filename, rails_blob_path(file, disposition: "attachment"), class: "text-sm text-accent hover:text-accent-hover" %>
        </li>
      <% end %>
    </ul>
  <% end %>
</div>
