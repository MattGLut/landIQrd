<div id="<%= dom_id(message) %>" class="rounded-lg bg-slate-50 dark:bg-slate-700 p-3">
  <div class="flex items-center justify-between gap-3">
    <div class="flex items-center gap-2">
      <%= render "shared/user_avatar", user: message.author, size: :sm %>
      <p class="text-sm font-medium text-slate-900 dark:text-slate-100"><%= message.author.display_name %></p>
    </div>
    <p class="text-xs text-slate-500 dark:text-slate-400"><%= message.created_at.to_fs(:short) %></p>
  </div>
  <% if message.body.present? %>
    <p class="mt-1 whitespace-pre-line text-sm text-slate-900 dark:text-slate-100"><%= message.body %></p>
  <% end %>
  <% if message.files.attached? %>
    <ul class="mt-2 space-y-1">
      <% message.files.each do |file| %>
        <li>
          <%= link_to file.filename, rails_blob_path(file, disposition: "attachment"), class: "text-sm text-brand-600 dark:text-brand-400 hover:text-brand-700 dark:hover:text-brand-300" %>
        </li>
      <% end %>
    </ul>
  <% end %>
</div>
