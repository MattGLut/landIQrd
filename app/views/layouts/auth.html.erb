<!DOCTYPE html>
<html class="dark h-full bg-[var(--color-surface)]" data-controller="theme">
  <head>
    <title><%= content_for(:title) || "LandIQrd" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="application-name" content="LandIQrd">
    <meta name="theme-color" content="#339e3d">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.svg">

    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="flex min-h-full items-center justify-center bg-[var(--color-surface)] px-4 py-12 text-[var(--color-text-primary)] antialiased">
    <% if notice.present? %>
      <div class="fixed top-4 left-1/2 z-50 w-full max-w-md -translate-x-1/2 rounded-md border border-emerald-200 bg-emerald-50 px-4 py-2 text-sm text-emerald-800 dark:border-emerald-800 dark:bg-emerald-900/30 dark:text-emerald-300"><%= notice %></div>
    <% end %>
    <% if alert.present? %>
      <div class="fixed top-4 left-1/2 z-50 w-full max-w-md -translate-x-1/2 rounded-md border border-rose-200 bg-rose-50 px-4 py-2 text-sm text-rose-800 dark:border-rose-800 dark:bg-rose-900/30 dark:text-rose-300"><%= alert %></div>
    <% end %>
    <div class="w-full max-w-md">
      <div class="mb-8 text-center">
        <%= link_to root_path, class: "text-2xl font-semibold tracking-tight text-navy-800 dark:text-navy-100" do %>
          Land<span class="text-brand-600 dark:text-brand-400">IQ</span>rd
        <% end %>
      </div>
      <%= yield %>
    </div>
  </body>
</html>
