<% content_for :title, "Resend unlock" %>

<h2 class="mb-6 text-2xl font-bold text-primary">Resend unlock instructions</h2>

<%= form_for(resource, as: resource_name, url: unlock_path(resource_name), html: { method: :post, class: "space-y-4 rounded-lg border border-border-default bg-surface p-6" }) do |f| %>
  <%= render "devise/shared/error_messages", resource: resource %>

  <div>
    <%= f.label :email, class: "block text-sm font-medium text-muted" %>
    <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "input-dark" %>
  </div>

  <%= f.submit "Resend unlock instructions", class: "w-full #{button_classes(:primary)}", data: { turbo_submits_with: "Sending…" } %>
<% end %>

<div class="mt-4 text-center text-sm text-muted">
  <%= render "devise/shared/links" %>
</div>
