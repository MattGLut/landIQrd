<% content_for :title, "Change password" %>

<h2 class="mb-6 text-2xl font-bold tracking-tight text-slate-900 dark:text-slate-100">Change your password</h2>

<%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put, class: "space-y-4 rounded-lg border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-700 dark:bg-slate-800" }) do |f| %>
  <%= render "devise/shared/error_messages", resource: resource %>
  <%= f.hidden_field :reset_password_token %>

  <div>
    <%= f.label :password, "New password", class: "block text-sm font-medium text-slate-500 dark:text-slate-400" %>
    <% if @minimum_password_length %>
      <p class="mt-0.5 text-xs text-slate-500 dark:text-slate-400">(<%= @minimum_password_length %> characters minimum)</p>
    <% end %>
    <%= f.password_field :password, autofocus: true, autocomplete: "new-password", class: form_input_class %>
  </div>

  <div>
    <%= f.label :password_confirmation, "Confirm new password", class: "block text-sm font-medium text-slate-500 dark:text-slate-400" %>
    <%= f.password_field :password_confirmation, autocomplete: "new-password", class: form_input_class %>
  </div>

  <%= f.submit "Change my password", class: "w-full #{button_classes(:primary)}", data: { turbo_submits_with: "Saving…" } %>
<% end %>

<div class="mt-4 text-center text-sm text-slate-500 dark:text-slate-400">
  <%= render "devise/shared/links" %>
</div>
