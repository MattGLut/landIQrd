<% content_for :title, "Log in" %>

<h2 class="mb-6 text-2xl font-bold text-primary">Log in to LandIQrd</h2>

<%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-4 rounded-lg border border-border-default bg-surface p-6" }) do |f| %>
  <div>
    <%= f.label :email, class: "block text-sm font-medium text-muted" %>
    <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "input-dark" %>
  </div>

  <div>
    <%= f.label :password, class: "block text-sm font-medium text-muted" %>
    <%= f.password_field :password, autocomplete: "current-password", class: "input-dark" %>
  </div>

  <% if devise_mapping.rememberable? %>
    <label class="flex items-center gap-2 text-sm text-muted">
      <%= f.check_box :remember_me, class: "rounded border-border-default bg-elevated text-accent focus:ring-accent" %>
      Remember me
    </label>
  <% end %>

  <%= f.submit "Log in", class: "w-full #{button_classes(:primary)}", data: { turbo_submits_with: "Logging in…" } %>
<% end %>

<div class="mt-4 text-center text-sm text-muted">
  <%= render "devise/shared/links" %>
</div>
