<% content_for :title, "Email & security" %>

<div class="mx-auto max-w-3xl">
  <%= render "shared/page_header", title: "Email & security", subtitle: "Update your sign-in credentials" %>

  <div class="mb-4">
    <%= link_to "← Back to account", edit_account_path, class: "text-sm text-accent hover:text-accent-hover" %>
  </div>

  <%= form_for(current_user, as: :user, url: registration_path(:user), html: { method: :put, class: "space-y-4 rounded-lg border border-border-default bg-surface p-6" }) do |f| %>
    <%= render "devise/shared/error_messages", resource: current_user %>

    <div>
      <%= f.label :email, class: "block text-sm font-medium text-muted" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "input-dark" %>
    </div>

    <div>
      <%= f.label :password, class: "block text-sm font-medium text-muted" %>
      <p class="text-xs text-muted">Leave blank if you don't want to change it</p>
      <%= f.password_field :password, autocomplete: "new-password", class: "input-dark" %>
    </div>

    <div>
      <%= f.label :password_confirmation, class: "block text-sm font-medium text-muted" %>
      <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "input-dark" %>
    </div>

    <div>
      <%= f.label :current_password, class: "block text-sm font-medium text-muted" %>
      <%= f.password_field :current_password, autocomplete: "current-password", class: "input-dark" %>
    </div>

    <%= f.submit "Update credentials", class: button_classes(:primary), data: { turbo_submits_with: "Saving…" } %>
  <% end %>
</div>
