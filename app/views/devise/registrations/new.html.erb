<% content_for :title, "Sign up" %>

<h2 class="mb-6 text-2xl font-bold tracking-tight text-slate-900 dark:text-slate-100">Create your account</h2>

<% if @invitation %>
  <p class="mb-4 rounded-lg border border-brand-200 dark:border-brand-800 bg-brand-50 dark:bg-brand-900/20 p-4 text-sm text-slate-900 dark:text-slate-100">
    You've been invited to join <%= @invitation.unit.property.name %> · <%= @invitation.unit.label %>.
  </p>
<% end %>

<%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-4 rounded-lg border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-700 dark:bg-slate-800" }) do |f| %>
  <%= render "devise/shared/error_messages", resource: resource %>
  <% if params[:invite_token].present? %>
    <%= hidden_field_tag :invite_token, params[:invite_token] %>
  <% end %>

  <div class="grid grid-cols-2 gap-4">
    <div>
      <%= f.label :first_name, class: "block text-sm font-medium text-slate-500 dark:text-slate-400" %>
      <%= f.text_field :first_name, autofocus: true, class: form_input_class %>
    </div>
    <div>
      <%= f.label :last_name, class: "block text-sm font-medium text-slate-500 dark:text-slate-400" %>
      <%= f.text_field :last_name, class: form_input_class %>
    </div>
  </div>

  <% unless @invitation %>
  <div>
    <%= f.label :role, "I am a", class: "block text-sm font-medium text-slate-500 dark:text-slate-400" %>
    <%= f.select :role, options_for_select(%w[tenant landlord contractor].map { |r| [ r.titleize, r ] }, resource.role), {}, class: form_input_class %>
  </div>
  <% end %>

  <div>
    <%= f.label :company_name, "Company (optional)", class: "block text-sm font-medium text-slate-500 dark:text-slate-400" %>
    <%= f.text_field :company_name, class: form_input_class %>
  </div>

  <div>
    <%= f.label :phone, "Phone (optional)", class: "block text-sm font-medium text-slate-500 dark:text-slate-400" %>
    <%= f.telephone_field :phone, class: form_input_class %>
  </div>

  <div>
    <%= f.label :email, class: "block text-sm font-medium text-slate-500 dark:text-slate-400" %>
    <%= f.email_field :email, autocomplete: "email", class: form_input_class %>
  </div>

  <div>
    <%= f.label :password, class: "block text-sm font-medium text-slate-500 dark:text-slate-400" %>
    <% if @minimum_password_length %>
      <span class="text-xs text-slate-500 dark:text-slate-400">(<%= @minimum_password_length %> characters minimum)</span>
    <% end %>
    <%= f.password_field :password, autocomplete: "new-password", class: form_input_class %>
  </div>

  <div>
    <%= f.label :password_confirmation, class: "block text-sm font-medium text-slate-500 dark:text-slate-400" %>
    <%= f.password_field :password_confirmation, autocomplete: "new-password", class: form_input_class %>
  </div>

  <%= f.submit "Sign up", class: "w-full #{button_classes(:primary)}", data: { turbo_submits_with: "Signing up…" } %>
<% end %>

<div class="mt-4 text-center text-sm text-slate-500 dark:text-slate-400">
  <%= render "devise/shared/links" %>
</div>
