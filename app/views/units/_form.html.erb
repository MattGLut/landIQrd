<%= form_with model: unit, url: form_url, class: "space-y-4 rounded-lg border border-border-default bg-surface p-6" do |f| %>
  <%= render "shared/form_errors", resource: unit %>

  <div>
    <%= f.label :label, "Unit label", class: "block text-sm font-medium text-muted" %>
    <%= f.text_field :label, placeholder: "e.g. Apt 2B", class: "input-dark" %>
  </div>

  <div class="grid grid-cols-3 gap-4">
    <div>
      <%= f.label :bedrooms, class: "block text-sm font-medium text-muted" %>
      <%= f.number_field :bedrooms, class: "input-dark" %>
    </div>
    <div>
      <%= f.label :bathrooms, class: "block text-sm font-medium text-muted" %>
      <%= f.number_field :bathrooms, step: 0.5, class: "input-dark" %>
    </div>
    <div>
      <%= f.label :square_feet, "Sq ft", class: "block text-sm font-medium text-muted" %>
      <%= f.number_field :square_feet, class: "input-dark" %>
    </div>
  </div>

  <div class="flex gap-2">
    <%= f.submit "Save", class: button_classes(:primary) %>
    <%= render "shared/button", label: "Cancel", url: cancel_url, variant: :secondary %>
  </div>
<% end %>
