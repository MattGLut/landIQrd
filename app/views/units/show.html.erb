<% content_for :title, @unit.label %>

<div class="mb-2 text-sm text-gray-500">
  <%= link_to @unit.property.name, property_path(@unit.property), class: "hover:text-gray-900" %> / <%= @unit.label %>
</div>

<div class="mb-6 flex items-start justify-between">
  <div>
    <h1 class="text-2xl font-bold"><%= @unit.label %></h1>
    <p class="text-gray-500">
      <%= [ @unit.bedrooms && "#{@unit.bedrooms} bd", @unit.bathrooms && "#{@unit.bathrooms} ba", @unit.square_feet && "#{@unit.square_feet} sqft" ].compact.join(" \u00b7 ") %>
    </p>
  </div>
  <div class="flex gap-2">
    <%= link_to "Edit", edit_unit_path(@unit), class: "rounded-md border border-gray-300 px-3 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50" %>
    <%= button_to "Delete", unit_path(@unit), method: :delete, class: "rounded-md border border-red-200 px-3 py-2 text-sm font-medium text-red-600 hover:bg-red-50", form: { data: { turbo_confirm: "Delete this unit?" } } %>
  </div>
</div>

<div class="mb-3 flex items-center justify-between">
  <h2 class="text-lg font-semibold">Leases</h2>
  <%= link_to "New lease", new_unit_lease_path(@unit), class: "text-sm font-medium text-indigo-600 hover:text-indigo-500" %>
</div>

<% if @unit.leases.any? %>
  <div class="space-y-2">
    <% @unit.leases.order(start_date: :desc).each do |lease| %>
      <%= link_to lease_path(lease), class: "flex items-center justify-between rounded-lg border border-gray-200 bg-white p-4 hover:border-indigo-300" do %>
        <div>
          <p class="font-medium"><%= lease.tenant.full_name %></p>
          <p class="text-sm text-gray-500"><%= lease.term_description %></p>
        </div>
        <%= status_badge lease.status.titleize, lease.active? ? :green : :gray %>
      <% end %>
    <% end %>
  </div>
<% else %>
  <p class="text-sm text-gray-500">No leases on this unit yet.</p>
<% end %>
