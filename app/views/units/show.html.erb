<% content_for :title, @unit.label %>

<%= property_breadcrumbs(
  { label: @unit.property.name, path: property_path(@unit.property) },
  { label: @unit.label, path: unit_path(@unit) }
) %>

<% header_actions = capture do %>
  <%= render "shared/button", label: "Edit", url: edit_unit_path(@unit), variant: :secondary, size: :sm %>
  <%= render "shared/button", label: "Delete", url: unit_path(@unit), variant: :danger_link, size: :sm, method: :delete, form: { data: { turbo_confirm: "Delete this unit?" }, class: "inline" } %>
<% end %>

<% subtitle_parts = [ property_type_badge(@unit.effective_type), @unit.summary_line.presence ].compact %>
<%= render "shared/page_header", title: @unit.label, subtitle: safe_join(subtitle_parts, tag.span(" \u00b7 ", class: "text-slate-300 dark:text-slate-600")), action: header_actions %>

<% if @unit.present_features.any? %>
  <details class="mb-6 rounded-lg border border-slate-200 bg-white p-4 shadow-sm dark:border-slate-700 dark:bg-slate-800">
    <summary class="cursor-pointer text-sm font-semibold text-slate-900 dark:text-slate-100">Unit features</summary>
    <dl class="mt-3 grid grid-cols-1 gap-2 text-sm sm:grid-cols-2">
      <% @unit.present_features.each do |entry| %>
        <div>
          <dt class="text-slate-500 dark:text-slate-400"><%= entry[:definition].label %></dt>
          <dd class="text-slate-900 dark:text-slate-100"><%= format_feature_value(entry[:definition], entry[:value]) %></dd>
        </div>
      <% end %>
    </dl>
  </details>
<% end %>

<div class="mb-3 flex items-center justify-between">
  <h2 class="text-lg font-semibold text-slate-900 dark:text-slate-100">Leases</h2>
  <% if @unit.leases.any? %>
    <div class="flex gap-2">
      <% if policy(@unit).update? %>
        <%= render "shared/button", label: "Invite tenant", url: new_unit_lease_invitation_path(@unit), variant: :ghost, size: :sm %>
      <% end %>
      <%= render "shared/button", label: "New lease", url: new_unit_lease_path(@unit), variant: :ghost, size: :sm %>
    </div>
  <% end %>
</div>

<% if @unit.leases.any? %>
  <div class="space-y-2">
    <% @unit.leases.order(start_date: :desc).each do |lease| %>
      <%= link_to lease_path(lease), class: "flex items-center justify-between rounded-lg border border-slate-200 bg-white p-4 shadow-sm dark:border-slate-700 dark:bg-slate-800 transition-colors hover:border-brand-300 dark:hover:border-brand-700" do %>
        <div>
          <p class="font-medium text-slate-900 dark:text-slate-100"><%= lease.tenant.full_name %></p>
          <p class="text-sm text-slate-500 dark:text-slate-400"><%= lease.term_description %></p>
        </div>
        <%= status_badge lease.status.titleize, lease.active? ? :green : :gray %>
      <% end %>
    <% end %>
  </div>
<% else %>
  <% empty_actions = capture do %>
    <div class="flex flex-wrap justify-center gap-2">
      <% if policy(@unit).update? %>
        <%= render "shared/button", label: "Invite tenant", url: new_unit_lease_invitation_path(@unit), variant: :primary %>
      <% end %>
      <%= render "shared/button", label: "New lease", url: new_unit_lease_path(@unit), variant: :secondary %>
    </div>
  <% end %>
  <%= render "shared/empty_state", message: "No leases on this unit yet.", action: empty_actions %>
<% end %>
