<% content_for :title, "Admin - Properties" %>

<%= render "shared/page_header", title: "Properties" %>
<%= render "admin/shared/nav" %>

<% if @properties.any? %>
<div class="overflow-hidden rounded-lg border border-border-default bg-surface">
  <table class="table-dark">
    <thead>
      <tr>
        <th>Property</th>
        <th>Landlord</th>
        <th>Units</th>
      </tr>
    </thead>
    <tbody>
      <% @properties.each do |property| %>
        <tr>
          <td>
            <%= link_to property.name, admin_property_path(property), class: "font-medium text-accent hover:text-accent-hover" %>
          </td>
          <td class="text-muted"><%= property.landlord.display_name %></td>
          <td class="text-primary"><%= property.units.size %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
<% else %>
  <%= render "shared/empty_state", message: "No properties yet." %>
<% end %>
