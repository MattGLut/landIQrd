<% content_for :title, "Admin - Properties" %>

<%= render "shared/page_header", title: "Properties" %>
<%= render "admin/shared/nav" %>

<% if @properties.any? %>
<div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm dark:border-slate-700 dark:bg-slate-800">
  <table class="table_class">
    <thead>
      <tr>
        <th>Property</th>
        <th>Landlord</th>
        <th>Units</th>
      </tr>
    </thead>
    <tbody>
      <% @properties.each do |property| %>
        <tr>
          <td>
            <%= link_to property.name, admin_property_path(property), class: "font-medium text-brand-600 dark:text-brand-400 hover:text-brand-700 dark:hover:text-brand-300" %>
          </td>
          <td class="text-slate-500 dark:text-slate-400"><%= property.landlord.display_name %></td>
          <td class="text-slate-900 dark:text-slate-100"><%= property.units.size %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
<% else %>
  <%= render "shared/empty_state", message: "No properties yet." %>
<% end %>
