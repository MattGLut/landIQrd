<% content_for :title, @property.name %>

<%= render "shared/page_header", title: "Admin console" %>
<%= render "admin/shared/nav" %>

<div class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-700 dark:bg-slate-800">
  <div class="flex items-center gap-2">
    <h2 class="text-xl font-bold text-slate-900 dark:text-slate-100"><%= @property.name %></h2>
    <%= property_type_badge(@property.property_type) %>
  </div>
  <p class="text-slate-500 dark:text-slate-400"><%= @property.full_address %></p>
  <p class="mt-2 text-sm text-slate-500 dark:text-slate-400">Landlord: <%= @property.landlord.display_name %> (<%= @property.landlord.email %>)</p>

  <% if @property.present_features.any? %>
    <h3 class="mt-4 mb-2 font-semibold text-slate-900 dark:text-slate-100">Property features</h3>
    <dl class="grid grid-cols-1 gap-2 text-sm sm:grid-cols-2">
      <% @property.present_features.each do |entry| %>
        <div>
          <dt class="text-slate-500 dark:text-slate-400"><%= entry[:definition].label %></dt>
          <dd class="text-slate-900 dark:text-slate-100"><%= format_feature_value(entry[:definition], entry[:value]) %></dd>
        </div>
      <% end %>
    </dl>
  <% end %>

  <h3 class="mt-4 mb-2 font-semibold text-slate-900 dark:text-slate-100">Units</h3>
  <ul class="space-y-2 text-sm">
    <% @property.units.each do |unit| %>
      <li class="flex justify-between gap-4 text-slate-900 dark:text-slate-100">
        <div>
          <span><%= unit.label %></span>
          <% if unit.summary_line.present? %>
            <span class="text-slate-500 dark:text-slate-400"> — <%= unit.summary_line %></span>
          <% end %>
        </div>
        <span class="shrink-0 text-slate-500 dark:text-slate-400"><%= pluralize(unit.leases.size, "lease") %></span>
      </li>
    <% end %>
  </ul>
</div>

<p class="mt-4">
  <%= link_to "Back to properties", admin_properties_path, class: "text-sm text-brand-600 dark:text-brand-400 hover:text-brand-700 dark:hover:text-brand-300" %>
</p>
