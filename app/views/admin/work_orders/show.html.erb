<% content_for :title, @work_order.title %>

<h1 class="mb-6 text-2xl font-bold">Admin console</h1>
<%= render "admin/shared/nav" %>

<div class="rounded-lg border border-gray-200 bg-white p-6">
  <div class="flex items-start justify-between">
    <div>
      <h2 class="text-xl font-bold"><%= @work_order.title %></h2>
      <p class="text-gray-500"><%= @work_order.unit.property.name %> &middot; <%= @work_order.unit.label %></p>
    </div>
    <div class="flex gap-2">
      <%= status_badge @work_order.priority.titleize, @work_order.priority_color %>
      <%= status_badge @work_order.status.titleize.gsub("_", " "), @work_order.status_color %>
    </div>
  </div>
  <p class="mt-4 whitespace-pre-line"><%= @work_order.description.presence || "No description." %></p>
  <p class="mt-4 text-sm text-gray-500">Reported by <%= @work_order.created_by.full_name %></p>

  <h3 class="mt-4 mb-2 font-semibold">Assigned contractors</h3>
  <% if @work_order.work_order_assignments.any? %>
    <ul class="space-y-1 text-sm">
      <% @work_order.work_order_assignments.includes(:contractor).each do |a| %>
        <li class="flex justify-between">
          <span><%= a.contractor.display_name %></span>
          <%= status_badge a.status.titleize, :gray %>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p class="text-sm text-gray-500">None assigned.</p>
  <% end %>
</div>

<p class="mt-4">
  <%= link_to "Back to work orders", admin_work_orders_path, class: "text-sm text-indigo-600 hover:text-indigo-500" %>
</p>
