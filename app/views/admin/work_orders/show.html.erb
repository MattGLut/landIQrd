<% content_for :title, @work_order.title %>

<%= render "shared/page_header", title: "Admin console" %>
<%= render "admin/shared/nav" %>

<div class="rounded-lg border border-border-default bg-surface p-6">
  <div class="flex items-start justify-between">
    <div>
      <h2 class="text-xl font-bold text-primary"><%= @work_order.title %></h2>
      <p class="text-muted"><%= @work_order.unit.property.name %> · <%= @work_order.unit.label %></p>
    </div>
    <div class="flex gap-2">
      <%= status_badge @work_order.priority.titleize, @work_order.priority_color %>
      <%= status_badge @work_order.status.titleize.gsub("_", " "), @work_order.status_color %>
    </div>
  </div>
  <p class="mt-4 whitespace-pre-line text-primary"><%= @work_order.description.presence || "No description." %></p>
  <p class="mt-4 text-sm text-muted">Reported by <%= @work_order.created_by.full_name %></p>
</div>

<p class="mt-4">
  <%= link_to "Back to work orders", admin_work_orders_path, class: "text-sm text-accent hover:text-accent-hover" %>
</p>
