<% content_for :title, "Admin - Work orders" %>

<%= render "shared/page_header", title: "Work orders" %>
<%= render "admin/shared/nav" %>

<% if @work_orders.any? %>
  <%= render "admin/shared/index_table" do %>
    <thead>
      <tr>
        <th class="w-[30%]">Title</th>
        <th class="w-[30%]">Property</th>
        <th class="w-[20%]">Priority</th>
        <th class="w-[20%]">Status</th>
      </tr>
    </thead>
    <tbody>
      <% @work_orders.each do |wo| %>
        <tr>
          <td>
            <%= link_to wo.title, admin_work_order_path(wo), class: admin_table_link_class %>
          </td>
          <td class="truncate <%= admin_table_muted_class %>"><%= wo.unit.property.name %> · <%= wo.unit.label %></td>
          <td><%= status_badge wo.priority.titleize, wo.priority_color %></td>
          <td><%= status_badge wo.status.titleize.gsub("_", " "), wo.status_color %></td>
        </tr>
      <% end %>
    </tbody>
  <% end %>
  <%= render "shared/pagination", collection: @work_orders %>
<% else %>
  <%= render "shared/empty_state", message: "No work orders yet." %>
<% end %>
