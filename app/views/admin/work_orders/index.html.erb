<% content_for :title, "Admin - Work orders" %>

<%= render "shared/page_header", title: "Admin console" %>
<%= render "admin/shared/nav" %>

<div class="overflow-hidden rounded-lg border border-border-default bg-surface">
  <table class="table-dark">
    <thead>
      <tr>
        <th>Title</th>
        <th>Property</th>
        <th>Priority</th>
        <th>Status</th>
      </tr>
    </thead>
    <tbody>
      <% @work_orders.each do |wo| %>
        <tr>
          <td>
            <%= link_to wo.title, admin_work_order_path(wo), class: "font-medium text-accent hover:text-accent-hover" %>
          </td>
          <td class="text-muted"><%= wo.unit.property.name %> · <%= wo.unit.label %></td>
          <td><%= status_badge wo.priority.titleize, wo.priority_color %></td>
          <td><%= status_badge wo.status.titleize.gsub("_", " "), wo.status_color %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
