<% content_for :title, "Admin" %>

<%= render "shared/page_header", title: "Admin console" %>
<%= render "admin/shared/nav" %>

<div class="grid gap-4 sm:grid-cols-4">
  <% [
    [ "Users", @users_count ],
    [ "Properties", @properties_count ],
    [ "Open work orders", @open_work_orders_count ],
    [ "Conversations", @conversations_count ]
  ].each do |label, count| %>
    <div class="rounded-lg border border-border-default bg-surface p-5">
      <p class="text-sm text-muted"><%= label %></p>
      <p class="mt-1 text-3xl font-bold <%= label == 'Open work orders' ? 'text-accent' : 'text-primary' %>"><%= count %></p>
    </div>
  <% end %>
</div>

<div class="mt-6 grid gap-6 sm:grid-cols-2">
  <div class="rounded-lg border border-border-default bg-surface p-5">
    <h2 class="mb-3 text-lg font-semibold text-primary">Users by role</h2>
    <ul class="space-y-1 text-sm">
      <% @users_by_role.each do |role, count| %>
        <li class="flex justify-between">
          <span class="text-muted"><%= role.titleize %></span>
          <span class="font-medium text-primary"><%= count %></span>
        </li>
      <% end %>
    </ul>
  </div>

  <div class="rounded-lg border border-border-default bg-surface p-5">
    <h2 class="mb-3 text-lg font-semibold text-primary">Recent work orders</h2>
    <% if @recent_work_orders.any? %>
      <ul class="space-y-2 text-sm">
        <% @recent_work_orders.each do |wo| %>
          <li class="flex justify-between">
            <%= link_to wo.title, admin_work_order_path(wo), class: "text-accent hover:text-accent-hover" %>
            <%= status_badge wo.status.titleize.gsub("_", " "), wo.status_color %>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="text-sm text-muted">No work orders yet.</p>
    <% end %>
  </div>
</div>
