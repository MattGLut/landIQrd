<% content_for :title, "Admin" %>

<%= render "shared/page_header", title: "Admin console" %>
<%= render "admin/shared/nav" %>

<div class="grid gap-4 sm:grid-cols-4">
  <% [
    [ "Users", @users_count, admin_users_path ],
    [ "Properties", @properties_count, admin_properties_path ],
    [ "Open work orders", @open_work_orders_count, admin_work_orders_path ],
    [ "Conversations", @conversations_count, admin_conversations_path ]
  ].each do |label, count, path| %>
    <%= link_to path, class: "rounded-xl border border-slate-200 bg-white p-5 shadow-sm transition-colors hover:border-brand-300 dark:border-slate-700 dark:bg-slate-800 dark:hover:border-brand-700" do %>
      <p class="text-sm text-slate-500 dark:text-slate-400"><%= label %></p>
      <p class="mt-1 text-3xl font-bold <%= label == 'Open work orders' ? 'text-brand-600 dark:text-brand-400' : 'text-slate-900 dark:text-slate-100' %>"><%= count %></p>
    <% end %>
  <% end %>
</div>

<div class="mt-6 grid gap-6 sm:grid-cols-2">
  <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm dark:border-slate-700 dark:bg-slate-800">
    <h2 class="mb-3 text-lg font-semibold text-slate-900 dark:text-slate-100">Users by role</h2>
    <ul class="space-y-1 text-sm">
      <% @users_by_role.each do |role, count| %>
        <li class="flex justify-between">
          <span class="text-slate-500 dark:text-slate-400"><%= role.titleize %></span>
          <span class="font-medium text-slate-900 dark:text-slate-100"><%= count %></span>
        </li>
      <% end %>
    </ul>
  </div>

  <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm dark:border-slate-700 dark:bg-slate-800">
    <h2 class="mb-3 text-lg font-semibold text-slate-900 dark:text-slate-100">Recent work orders</h2>
    <% if @recent_work_orders.any? %>
      <ul class="space-y-2 text-sm">
        <% @recent_work_orders.each do |wo| %>
          <li class="flex justify-between">
            <%= link_to wo.title, admin_work_order_path(wo), class: "text-brand-600 dark:text-brand-400 hover:text-brand-700 dark:hover:text-brand-300" %>
            <%= status_badge wo.status.titleize.gsub("_", " "), wo.status_color %>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="text-sm text-slate-500 dark:text-slate-400">No work orders yet.</p>
    <% end %>
  </div>
</div>
