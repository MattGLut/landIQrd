<% content_for :title, "Admin - Conversations" %>

<%= render "shared/page_header", title: "Conversations" %>
<%= render "admin/shared/nav" %>

<% if @conversations.any? %>
<div class="space-y-2">
  <% @conversations.each do |conversation| %>
    <%= link_to admin_conversation_path(conversation), class: "block rounded-lg border border-slate-200 bg-white p-4 shadow-sm dark:border-slate-700 dark:bg-slate-800 transition-colors hover:border-brand-300 dark:hover:border-brand-700" do %>
      <div class="flex items-center gap-2">
        <p class="min-w-0 flex-1 truncate font-medium text-slate-900 dark:text-slate-100"><%= conversation.title %></p>
        <% if conversation.work_order %><%= status_badge "Work order", :indigo %><% end %>
      </div>
      <p class="mt-1 text-xs text-slate-500 dark:text-slate-400"><%= conversation.participants.map(&:display_name).join(", ") %></p>
    <% end %>
  <% end %>
</div>
<% else %>
  <%= render "shared/empty_state", message: "No conversations yet." %>
<% end %>
