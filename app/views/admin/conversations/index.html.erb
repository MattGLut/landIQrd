<% content_for :title, "Admin - Conversations" %>

<h1 class="mb-6 text-2xl font-bold">Admin console</h1>
<%= render "admin/shared/nav" %>

<div class="space-y-2">
  <% @conversations.each do |conversation| %>
    <%= link_to admin_conversation_path(conversation), class: "block rounded-lg border border-gray-200 bg-white p-4 hover:border-indigo-300" do %>
      <div class="flex items-center justify-between">
        <p class="font-medium"><%= conversation.title %></p>
        <% if conversation.work_order %><%= status_badge "Work order", :indigo %><% end %>
      </div>
      <p class="mt-1 text-xs text-gray-400"><%= conversation.participants.map(&:display_name).join(", ") %></p>
    <% end %>
  <% end %>
</div>
