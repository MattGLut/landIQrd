<% content_for :title, "Admin - Conversations" %>

<%= render "shared/page_header", title: "Conversations" %>
<%= render "admin/shared/nav" %>

<% if @conversations.any? %>
  <%= render "admin/shared/index_table" do %>
    <thead>
      <tr>
        <th class="w-[35%]">Conversation</th>
        <th class="w-[45%]">Participants</th>
        <th class="w-[20%]">Type</th>
      </tr>
    </thead>
    <tbody>
      <% @conversations.each do |conversation| %>
        <tr>
          <td>
            <%= link_to conversation.title, admin_conversation_path(conversation), class: admin_table_link_class %>
          </td>
          <td class="truncate <%= admin_table_muted_class %>"><%= conversation.participants.map(&:display_name).join(", ") %></td>
          <td>
            <% if conversation.work_order %>
              <%= status_badge "Work order", :indigo %>
            <% else %>
              <%= status_badge "Direct", :gray %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  <% end %>
  <%= render "shared/pagination", collection: @conversations %>
<% else %>
  <%= render "shared/empty_state", message: "No conversations yet." %>
<% end %>
