<% content_for :title, @conversation.title %>

<%= render "shared/page_header", title: "Admin console" %>
<%= render "admin/shared/nav" %>

<div class="mb-4">
  <h2 class="text-xl font-bold text-slate-900 dark:text-slate-100"><%= @conversation.title %></h2>
  <p class="text-sm text-slate-500 dark:text-slate-400"><%= @conversation.participants.map(&:display_name).join(", ") %></p>
</div>

<div class="space-y-3 rounded-lg border border-slate-200 bg-white p-4 shadow-sm dark:border-slate-700 dark:bg-slate-800">
  <% if @messages.any? %>
    <%= render partial: "messages/message", collection: @messages %>
  <% else %>
    <p class="text-sm text-slate-500 dark:text-slate-400">No messages.</p>
  <% end %>
</div>

<p class="mt-4">
  <%= link_to "Back to conversations", admin_conversations_path, class: "text-sm text-brand-600 dark:text-brand-400 hover:text-brand-700 dark:hover:text-brand-300" %>
</p>
