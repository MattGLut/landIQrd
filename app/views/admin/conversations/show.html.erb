<% content_for :title, @conversation.title %>

<%= render "shared/page_header", title: "Admin console" %>
<%= render "admin/shared/nav" %>

<div class="mb-4">
  <h2 class="text-xl font-bold text-primary"><%= @conversation.title %></h2>
  <p class="text-sm text-muted"><%= @conversation.participants.map(&:display_name).join(", ") %></p>
</div>

<div class="space-y-3 rounded-lg border border-border-default bg-surface p-4">
  <% if @messages.any? %>
    <%= render @messages %>
  <% else %>
    <p class="text-sm text-muted">No messages.</p>
  <% end %>
</div>

<p class="mt-4">
  <%= link_to "Back to conversations", admin_conversations_path, class: "text-sm text-accent hover:text-accent-hover" %>
</p>
