<% content_for :title, "Admin - Users" %>

<%= render "shared/page_header", title: "Admin console" %>
<%= render "admin/shared/nav" %>

<div class="mb-4 flex items-center justify-between">
  <h2 class="text-lg font-semibold text-primary">Users</h2>
  <%= render "shared/button", label: "New user", url: new_admin_user_path, variant: :primary %>
</div>

<div class="overflow-hidden rounded-lg border border-border-default bg-surface">
  <table class="table-dark">
    <thead>
      <tr>
        <th>Name</th>
        <th>Email</th>
        <th>Role</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% @users.each do |user| %>
        <tr>
          <td class="font-medium text-primary"><%= user.full_name %></td>
          <td class="text-muted"><%= user.email %></td>
          <td><%= status_badge user.role.titleize, :gray %></td>
          <td class="text-right">
            <%= link_to "View", admin_user_path(user), class: "text-accent hover:text-accent-hover" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
