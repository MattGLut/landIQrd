<% content_for :title, "Admin - Users" %>

<%= render "shared/page_header",
           title: "Users",
           action: render("shared/button", label: "New user", url: new_admin_user_path, variant: :primary) %>
<%= render "admin/shared/nav" %>

<% if @users.any? %>
  <%= render "admin/shared/index_table" do %>
    <thead>
      <tr>
        <th class="w-[30%]">Name</th>
        <th class="w-[40%]">Email</th>
        <th class="w-[30%]">Role</th>
      </tr>
    </thead>
    <tbody>
      <% @users.each do |user| %>
        <tr>
          <td>
            <%= link_to user.full_name, admin_user_path(user), class: admin_table_link_class %>
          </td>
          <td class="truncate <%= admin_table_muted_class %>"><%= user.email %></td>
          <td><%= status_badge user.role.titleize, :gray %></td>
        </tr>
      <% end %>
    </tbody>
  <% end %>
  <%= render "shared/pagination", collection: @users %>
<% else %>
  <%= render "shared/empty_state", message: "No users yet.", action: render("shared/button", label: "New user", url: new_admin_user_path, variant: :primary) %>
<% end %>
