<% content_for :title, @user.full_name %>

<% header_actions = capture do %>
  <%= render "shared/button", label: "Edit", url: edit_admin_user_path(@user), variant: :secondary, size: :sm %>
  <% unless @user == current_user %>
    <%= render "shared/button", label: "Delete", url: admin_user_path(@user), variant: :danger_link, size: :sm, method: :delete, form: { data: { turbo_confirm: "Delete this user?" }, class: "inline" } %>
  <% end %>
<% end %>

<%= render "shared/page_header", title: @user.full_name, subtitle: @user.email, action: header_actions %>

<div class="mb-2"><%= status_badge @user.role.titleize, :gray %></div>

<dl class="grid grid-cols-2 gap-4 rounded-lg border border-border-default bg-surface p-6">
  <div>
    <dt class="text-sm text-muted">Phone</dt>
    <dd class="mt-1 text-primary"><%= @user.phone.presence || "—" %></dd>
  </div>
  <div>
    <dt class="text-sm text-muted">Company</dt>
    <dd class="mt-1 text-primary"><%= @user.company_name.presence || "—" %></dd>
  </div>
  <div>
    <dt class="text-sm text-muted">Joined</dt>
    <dd class="mt-1 text-primary"><%= @user.created_at.to_fs(:long) %></dd>
  </div>
</dl>

<p class="mt-4">
  <%= link_to "Back to users", admin_users_path, class: "text-sm text-accent hover:text-accent-hover" %>
</p>
