<% content_for :title, @user.full_name %>

<% header_actions = capture do %>
  <%= render "shared/button", label: "Edit", url: edit_admin_user_path(@user), variant: :secondary, size: :sm %>
  <% unless @user == current_user %>
    <%= render "shared/button", label: "Delete", url: admin_user_path(@user), variant: :danger_link, size: :sm, method: :delete, form: { data: { turbo_confirm: "Delete this user?" }, class: "inline" } %>
  <% end %>
<% end %>

<%= render "shared/page_header", title: @user.full_name, subtitle: @user.email, action: header_actions %>

<div class="mb-2"><%= status_badge @user.role.titleize, :gray %></div>

<dl class="grid grid-cols-2 gap-4 rounded-lg border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-700 dark:bg-slate-800">
  <div>
    <dt class="text-sm text-slate-500 dark:text-slate-400">Phone</dt>
    <dd class="mt-1 text-slate-900 dark:text-slate-100"><%= @user.phone.presence || "—" %></dd>
  </div>
  <div>
    <dt class="text-sm text-slate-500 dark:text-slate-400">Company</dt>
    <dd class="mt-1 text-slate-900 dark:text-slate-100"><%= @user.company_name.presence || "—" %></dd>
  </div>
  <div>
    <dt class="text-sm text-slate-500 dark:text-slate-400">Joined</dt>
    <dd class="mt-1 text-slate-900 dark:text-slate-100"><%= @user.created_at.to_fs(:long) %></dd>
  </div>
</dl>

<p class="mt-4">
  <%= link_to "Back to users", admin_users_path, class: "text-sm text-brand-600 dark:text-brand-400 hover:text-brand-700 dark:hover:text-brand-300" %>
</p>
