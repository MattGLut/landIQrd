<%= form_with model: user, url: form_url, class: "space-y-4 rounded-lg border border-border-default bg-surface p-6" do |f| %>
  <%= render "shared/form_errors", resource: user %>

  <div class="grid grid-cols-2 gap-4">
    <div>
      <%= f.label :first_name, class: "block text-sm font-medium text-muted" %>
      <%= f.text_field :first_name, class: "input-dark" %>
    </div>
    <div>
      <%= f.label :last_name, class: "block text-sm font-medium text-muted" %>
      <%= f.text_field :last_name, class: "input-dark" %>
    </div>
  </div>

  <div>
    <%= f.label :role, class: "block text-sm font-medium text-muted" %>
    <%= f.select :role, User.roles.keys.map { |r| [ r.titleize, r ] }, {}, class: "input-dark" %>
  </div>

  <div>
    <%= f.label :email, class: "block text-sm font-medium text-muted" %>
    <%= f.email_field :email, class: "input-dark" %>
  </div>

  <div class="grid grid-cols-2 gap-4">
    <div>
      <%= f.label :phone, class: "block text-sm font-medium text-muted" %>
      <%= f.telephone_field :phone, class: "input-dark" %>
    </div>
    <div>
      <%= f.label :company_name, class: "block text-sm font-medium text-muted" %>
      <%= f.text_field :company_name, class: "input-dark" %>
    </div>
  </div>

  <div class="grid grid-cols-2 gap-4">
    <div>
      <%= f.label :password, class: "block text-sm font-medium text-muted" %>
      <% if user.persisted? %><span class="text-xs text-muted">(leave blank to keep current)</span><% end %>
      <%= f.password_field :password, autocomplete: "new-password", class: "input-dark" %>
    </div>
    <div>
      <%= f.label :password_confirmation, class: "block text-sm font-medium text-muted" %>
      <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "input-dark" %>
    </div>
  </div>

  <div class="flex gap-2">
    <%= f.submit "Save", class: button_classes(:primary) %>
    <%= render "shared/button", label: "Cancel", url: admin_users_path, variant: :secondary %>
  </div>
<% end %>
