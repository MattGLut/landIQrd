<%= form_with model: user, url: form_url, class: "space-y-4 rounded-lg border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-700 dark:bg-slate-800" do |f| %>
  <%= render "shared/form_errors", resource: user %>

  <div class="grid grid-cols-2 gap-4">
    <div>
      <%= f.label :first_name, class: "block text-sm font-medium text-slate-500 dark:text-slate-400" %>
      <%= f.text_field :first_name, class: form_input_class %>
    </div>
    <div>
      <%= f.label :last_name, class: "block text-sm font-medium text-slate-500 dark:text-slate-400" %>
      <%= f.text_field :last_name, class: form_input_class %>
    </div>
  </div>

  <div>
    <%= f.label :role, class: "block text-sm font-medium text-slate-500 dark:text-slate-400" %>
    <%= f.select :role, User.roles.keys.map { |r| [ r.titleize, r ] }, {}, class: form_input_class %>
  </div>

  <div>
    <%= f.label :email, class: "block text-sm font-medium text-slate-500 dark:text-slate-400" %>
    <%= f.email_field :email, class: form_input_class %>
  </div>

  <div class="grid grid-cols-2 gap-4">
    <div>
      <%= f.label :phone, class: "block text-sm font-medium text-slate-500 dark:text-slate-400" %>
      <%= f.telephone_field :phone, class: form_input_class %>
    </div>
    <div>
      <%= f.label :company_name, class: "block text-sm font-medium text-slate-500 dark:text-slate-400" %>
      <%= f.text_field :company_name, class: form_input_class %>
    </div>
  </div>

  <div class="grid grid-cols-2 gap-4">
    <div>
      <%= f.label :password, class: "block text-sm font-medium text-slate-500 dark:text-slate-400" %>
      <% if user.persisted? %><span class="text-xs text-slate-500 dark:text-slate-400">(leave blank to keep current)</span><% end %>
      <%= f.password_field :password, autocomplete: "new-password", class: form_input_class %>
    </div>
    <div>
      <%= f.label :password_confirmation, class: "block text-sm font-medium text-slate-500 dark:text-slate-400" %>
      <%= f.password_field :password_confirmation, autocomplete: "new-password", class: form_input_class %>
    </div>
  </div>

  <div class="flex gap-2">
    <%= f.submit "Save", class: button_classes(:primary), data: { turbo_submits_with: "Saving…" } %>
    <%= render "shared/button", label: "Cancel", url: admin_users_path, variant: :secondary %>
  </div>
<% end %>
