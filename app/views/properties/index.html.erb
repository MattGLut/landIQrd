<% content_for :title, "Properties" %>

<%= render "shared/page_header", title: "Properties", action: render("shared/button", label: "New property", url: new_property_path, variant: :primary) %>

<% if @properties.any? %>
  <div class="grid gap-4 sm:grid-cols-2">
    <%= render @properties %>
  </div>
<% else %>
  <%= render "shared/empty_state", message: "No properties yet. Add your first one to get started.", action: render("shared/button", label: "Add property", url: new_property_path, variant: :primary) %>
<% end %>
