<% content_for :title, "Properties" %>

<div class="mb-6 flex items-center justify-between">
  <h1 class="text-2xl font-bold">Properties</h1>
  <%= link_to "New property", new_property_path, class: "rounded-md bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-500" %>
</div>

<% if @properties.any? %>
  <div class="grid gap-4 sm:grid-cols-2">
    <%= render @properties %>
  </div>
<% else %>
  <div class="rounded-lg border border-dashed border-gray-300 bg-white p-10 text-center text-gray-500">
    No properties yet. Add your first one to get started.
  </div>
<% end %>
