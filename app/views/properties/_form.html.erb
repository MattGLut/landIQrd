<%= form_with model: property, class: "space-y-4 rounded-lg border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-700 dark:bg-slate-800", data: { controller: "property-type-form", property_type_form_mode_value: "property" } do |f| %>
  <%= render "shared/form_errors", resource: property %>

  <div>
    <%= f.label :property_type, "Property type", class: "block text-sm font-medium text-slate-500 dark:text-slate-400" %>
    <%= f.select :property_type, property_type_options, {}, class: form_input_class, data: { property_type_form_target: "typeSelect", action: "property-type-form#typeChanged" } %>
    <p class="mt-1 text-sm text-slate-500 dark:text-slate-400" data-property-type-form-target="typeHint"></p>
  </div>

  <% if property.persisted? && property.units_with_type_overrides? %>
    <p class="rounded-md border border-amber-200 bg-amber-50 px-3 py-2 text-sm text-amber-800 dark:border-amber-800 dark:bg-amber-900/20 dark:text-amber-200">
      Some units on this property have a different type override. Changing the property type will not update those units automatically.
    </p>
  <% end %>

  <div>
    <%= f.label :name, class: "block text-sm font-medium text-slate-500 dark:text-slate-400" %>
    <%= f.text_field :name, class: form_input_class %>
  </div>

  <div>
    <%= f.label :address_line1, "Address", class: "block text-sm font-medium text-slate-500 dark:text-slate-400" %>
    <%= f.text_field :address_line1, class: form_input_class %>
  </div>

  <div>
    <%= f.label :address_line2, "Address line 2", class: "block text-sm font-medium text-slate-500 dark:text-slate-400" %>
    <%= f.text_field :address_line2, class: form_input_class %>
  </div>

  <div class="grid grid-cols-1 gap-4 sm:grid-cols-3">
    <div>
      <%= f.label :city, class: "block text-sm font-medium text-slate-500 dark:text-slate-400" %>
      <%= f.text_field :city, class: form_input_class %>
    </div>
    <div>
      <%= f.label :state, class: "block text-sm font-medium text-slate-500 dark:text-slate-400" %>
      <%= f.text_field :state, class: form_input_class %>
    </div>
    <div>
      <%= f.label :postal_code, "ZIP", class: "block text-sm font-medium text-slate-500 dark:text-slate-400" %>
      <%= f.text_field :postal_code, class: form_input_class %>
    </div>
  </div>

  <%= render "features_fields", record: property, form_scope: "property" %>

  <div class="flex gap-2">
    <%= f.submit "Save", class: button_classes(:primary), data: { turbo_submits_with: "Saving…" } %>
    <%= render "shared/button", label: "Cancel", url: properties_path, variant: :secondary %>
  </div>
<% end %>
