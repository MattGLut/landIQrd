<%= form_with model: property, class: "space-y-4 rounded-lg border border-border-default bg-surface p-6" do |f| %>
  <%= render "shared/form_errors", resource: property %>

  <div>
    <%= f.label :name, class: "block text-sm font-medium text-muted" %>
    <%= f.text_field :name, class: "input-dark" %>
  </div>

  <div>
    <%= f.label :address_line1, "Address", class: "block text-sm font-medium text-muted" %>
    <%= f.text_field :address_line1, class: "input-dark" %>
  </div>

  <div>
    <%= f.label :address_line2, "Address line 2", class: "block text-sm font-medium text-muted" %>
    <%= f.text_field :address_line2, class: "input-dark" %>
  </div>

  <div class="grid grid-cols-3 gap-4">
    <div>
      <%= f.label :city, class: "block text-sm font-medium text-muted" %>
      <%= f.text_field :city, class: "input-dark" %>
    </div>
    <div>
      <%= f.label :state, class: "block text-sm font-medium text-muted" %>
      <%= f.text_field :state, class: "input-dark" %>
    </div>
    <div>
      <%= f.label :postal_code, "ZIP", class: "block text-sm font-medium text-muted" %>
      <%= f.text_field :postal_code, class: "input-dark" %>
    </div>
  </div>

  <div class="flex gap-2">
    <%= f.submit "Save", class: button_classes(:primary) %>
    <%= render "shared/button", label: "Cancel", url: properties_path, variant: :secondary %>
  </div>
<% end %>
