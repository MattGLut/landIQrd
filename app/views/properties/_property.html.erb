<%= link_to property_path(property), class: "block rounded-lg border border-border-default bg-surface p-5 transition-colors hover:border-accent/50" do %>
  <p class="font-medium text-primary"><%= property.name %></p>
  <p class="text-sm text-muted"><%= property.full_address.presence || "No address on file" %></p>
  <p class="mt-2 text-xs text-muted"><%= pluralize(property.units.size, "unit") %></p>
<% end %>
