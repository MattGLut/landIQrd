<% content_for :title, @property.name %>

<% header_actions = capture do %>
  <%= render "shared/button", label: "Edit", url: edit_property_path(@property), variant: :secondary, size: :sm %>
  <%= render "shared/button", label: "Delete", url: property_path(@property), variant: :danger_link, size: :sm, method: :delete, form: { data: { turbo_confirm: "Delete this property and all its units?" }, class: "inline" } %>
<% end %>

<%= render "shared/page_header", title: @property.name, subtitle: @property.full_address.presence || "No address on file", action: header_actions %>

<div class="mb-3 flex items-center justify-between">
  <h2 class="text-lg font-semibold text-slate-900 dark:text-slate-100">Units</h2>
  <% if @property.units.any? %>
    <%= render "shared/button", label: "Add unit", url: new_property_unit_path(@property), variant: :ghost, size: :sm %>
  <% end %>
</div>

<% if @property.units.any? %>
  <div class="space-y-2">
    <% @property.units.order(:label).each do |unit| %>
      <%= link_to unit_path(unit), class: "block rounded-lg border border-slate-200 bg-white p-4 shadow-sm dark:border-slate-700 dark:bg-slate-800 transition-colors hover:border-brand-300 dark:hover:border-brand-700" do %>
        <div class="flex items-center justify-between">
          <div>
            <p class="font-medium text-slate-900 dark:text-slate-100"><%= unit.label %></p>
            <p class="text-sm text-slate-500 dark:text-slate-400">
              <%= [ unit.bedrooms && "#{unit.bedrooms} bd", unit.bathrooms && "#{unit.bathrooms} ba", unit.square_feet && "#{unit.square_feet} sqft" ].compact.join(" \u00b7 ") %>
            </p>
          </div>
          <span class="text-sm text-slate-500 dark:text-slate-400"><%= pluralize(unit.leases.size, "lease") %></span>
        </div>
      <% end %>
    <% end %>
  </div>
<% else %>
  <%= render "shared/empty_state",
    message: "No units yet.",
    action: render("shared/button", label: "Add unit", url: new_property_unit_path(@property), variant: :primary) %>
<% end %>
