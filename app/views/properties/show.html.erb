<% content_for :title, @property.name %>

<% header_actions = capture do %>
  <%= render "shared/button", label: "Edit", url: edit_property_path(@property), variant: :secondary, size: :sm %>
  <%= render "shared/button", label: "Delete", url: property_path(@property), variant: :danger_link, size: :sm, method: :delete, form: { data: { turbo_confirm: "Delete this property and all its units?" }, class: "inline" } %>
<% end %>

<% subtitle_parts = [ property_type_badge(@property.property_type), @property.full_address.presence ].compact %>
<%= render "shared/page_header", title: @property.name, subtitle: safe_join(subtitle_parts, tag.span(" \u00b7 ", class: "text-slate-300 dark:text-slate-600")), action: header_actions %>

<% if @property.present_features.any? %>
  <details class="mb-6 rounded-lg border border-slate-200 bg-white p-4 shadow-sm dark:border-slate-700 dark:bg-slate-800">
    <summary class="cursor-pointer text-sm font-semibold text-slate-900 dark:text-slate-100">Property features</summary>
    <dl class="mt-3 grid grid-cols-1 gap-2 text-sm sm:grid-cols-2">
      <% @property.present_features.each do |entry| %>
        <div>
          <dt class="text-slate-500 dark:text-slate-400"><%= entry[:definition].label %></dt>
          <dd class="text-slate-900 dark:text-slate-100"><%= format_feature_value(entry[:definition], entry[:value]) %></dd>
        </div>
      <% end %>
    </dl>
  </details>
<% end %>

<div class="mb-3 flex items-center justify-between">
  <h2 class="text-lg font-semibold text-slate-900 dark:text-slate-100">Units</h2>
  <% if @property.units.any? %>
    <%= render "shared/button", label: "Add unit", url: new_property_unit_path(@property), variant: :ghost, size: :sm %>
  <% end %>
</div>

<% if @property.units.any? %>
  <div class="space-y-2">
    <% @property.units.order(:label).each do |unit| %>
      <%= link_to unit_path(unit), class: "block rounded-lg border border-slate-200 bg-white p-4 shadow-sm dark:border-slate-700 dark:bg-slate-800 transition-colors hover:border-brand-300 dark:hover:border-brand-700" do %>
        <div class="flex items-center justify-between">
          <div>
            <div class="flex items-center gap-2">
              <p class="font-medium text-slate-900 dark:text-slate-100"><%= unit.label %></p>
              <% if unit.unit_type.present? %>
                <%= property_type_badge(unit.effective_type) %>
              <% end %>
            </div>
            <% if unit.summary_line.present? %>
              <p class="text-sm text-slate-500 dark:text-slate-400"><%= unit.summary_line %></p>
            <% end %>
          </div>
          <span class="text-sm text-slate-500 dark:text-slate-400"><%= pluralize(unit.leases.size, "lease") %></span>
        </div>
      <% end %>
    <% end %>
  </div>
<% else %>
  <%= render "shared/empty_state",
    message: "No units yet.",
    action: render("shared/button", label: "Add unit", url: new_property_unit_path(@property), variant: :primary) %>
<% end %>
