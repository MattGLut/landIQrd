<% content_for :title, "Messages" %>

<div class="flex h-[calc(100vh-8rem)] flex-col lg:flex-row lg:gap-4">
  <div class="<%= @conversation ? 'hidden lg:flex' : 'flex' %> w-full flex-col border-border-default lg:w-80 lg:shrink-0 lg:border-r lg:pr-4">
    <h1 class="mb-4 text-xl font-bold text-primary lg:hidden">Messages</h1>
    <% if @conversations.any? %>
      <div class="flex-1 space-y-1 overflow-y-auto">
        <% @conversations.each do |conversation| %>
          <% active = @conversation&.id == conversation.id %>
          <%= link_to conversation_path(conversation), class: "block rounded-lg border p-3 transition-colors #{active ? 'border-accent/50 bg-accent/10' : 'border-border-default bg-surface hover:border-accent/30'}" do %>
            <div class="flex items-center justify-between">
              <p class="truncate font-medium text-primary"><%= conversation.title %></p>
              <% if conversation.work_order %>
                <%= status_badge "Work order", :indigo %>
              <% end %>
            </div>
            <p class="mt-1 truncate text-sm text-muted">
              <%= conversation.latest_message&.body.presence || "No messages yet" %>
            </p>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <%= render "shared/empty_state", message: "No conversations yet." %>
    <% end %>
  </div>

  <div class="<%= @conversation ? 'flex' : 'hidden lg:flex' %> min-h-0 flex-1 flex-col">
    <% if @conversation %>
      <div class="mb-4 lg:hidden">
        <%= link_to "← Back to messages", conversations_path, class: "text-sm text-accent hover:text-accent-hover" %>
      </div>
      <%= render "conversations/thread", conversation: @conversation, messages: @messages, message: @message %>
    <% else %>
      <div class="flex flex-1 items-center justify-center rounded-lg border border-dashed border-border-default bg-surface">
        <p class="text-muted">Select a conversation to view messages</p>
      </div>
    <% end %>
  </div>
</div>
