<% content_for :title, "Messages" %>

<h1 class="mb-6 text-2xl font-bold">Messages</h1>

<% if @conversations.any? %>
  <div class="space-y-2">
    <% @conversations.each do |conversation| %>
      <%= link_to conversation_path(conversation), class: "block rounded-lg border border-gray-200 bg-white p-4 hover:border-indigo-300" do %>
        <div class="flex items-center justify-between">
          <p class="font-medium"><%= conversation.title %></p>
          <% if conversation.work_order %>
            <%= status_badge "Work order", :indigo %>
          <% end %>
        </div>
        <p class="mt-1 truncate text-sm text-gray-500">
          <%= conversation.latest_message&.body.presence || "No messages yet" %>
        </p>
        <p class="mt-1 text-xs text-gray-400">
          <%= conversation.participants.map(&:display_name).join(", ") %>
        </p>
      <% end %>
    <% end %>
  </div>
<% else %>
  <div class="rounded-lg border border-dashed border-gray-300 bg-white p-10 text-center text-gray-500">
    No conversations yet.
  </div>
<% end %>
