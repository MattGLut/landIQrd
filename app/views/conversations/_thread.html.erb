<%= turbo_stream_from conversation %>

<div class="flex h-full flex-col">
  <div class="mb-4 border-b border-slate-200 dark:border-slate-700 pb-4">
    <div class="<%= conversation.work_order ? "flex flex-col items-start gap-2 lg:flex-row lg:gap-4" : "" %>">
      <div class="min-w-0">
        <h2 class="text-lg font-bold text-slate-900 dark:text-slate-100"><%= conversation.title %></h2>
        <p class="text-sm text-slate-500 dark:text-slate-400"><%= conversation.participants.map(&:display_name).join(", ") %></p>
      </div>
      <% if conversation.work_order %>
        <div class="ml-auto shrink-0">
          <%= link_to "View work order", work_order_path(conversation.work_order), class: "whitespace-nowrap text-sm font-medium text-brand-600 dark:text-brand-400 hover:text-brand-700 dark:hover:text-brand-300" %>
        </div>
      <% end %>
    </div>
  </div>

  <div id="messages" class="flex-1 space-y-3 overflow-y-auto rounded-lg border border-slate-200 bg-white p-4 shadow-sm dark:border-slate-700 dark:bg-slate-800">
    <% if messages.any? %>
      <%= render messages %>
    <% else %>
      <p class="text-sm text-slate-500 dark:text-slate-400" id="empty-thread">No messages yet. Say hello.</p>
    <% end %>
  </div>

  <div id="new_message" class="mt-4">
    <%= render "messages/form", conversation: conversation, message: message %>
  </div>
</div>
