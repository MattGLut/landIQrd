<% content_for :title, @conversation.title %>

<%= turbo_stream_from @conversation %>

<div class="mb-4 flex items-center justify-between">
  <div>
    <h1 class="text-2xl font-bold"><%= @conversation.title %></h1>
    <p class="text-sm text-gray-500"><%= @conversation.participants.map(&:display_name).join(", ") %></p>
  </div>
  <%= link_to "Back to messages", conversations_path, class: "text-sm text-indigo-600 hover:text-indigo-500" %>
</div>

<% if @conversation.work_order %>
  <div class="mb-4">
    <%= link_to "View work order", work_order_path(@conversation.work_order), class: "text-sm font-medium text-indigo-600 hover:text-indigo-500" %>
  </div>
<% end %>

<div id="messages" class="space-y-3 rounded-lg border border-gray-200 bg-white p-4">
  <% if @messages.any? %>
    <%= render @messages %>
  <% else %>
    <p class="text-sm text-gray-500" id="empty-thread">No messages yet. Say hello.</p>
  <% end %>
</div>

<div id="new_message" class="mt-4">
  <%= render "messages/form", conversation: @conversation, message: @message %>
</div>
