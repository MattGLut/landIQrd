<% content_for :title, @contractor.display_name %>

<% header_subtitle = if @contractor.company_name.present? && @contractor.display_name == @contractor.company_name
                       @contractor.full_name if @contractor.full_name != @contractor.display_name
                     elsif @contractor.company_name.present? && @contractor.company_name != @contractor.display_name
                       @contractor.company_name
                     end %>

<div class="mb-8 flex flex-wrap items-start gap-5">
  <%= render "shared/user_avatar", user: @contractor, size: :lg %>
  <div class="min-w-0 flex-1 grid grid-cols-1 gap-x-8 gap-y-3 sm:grid-cols-2 sm:items-start">
    <div>
      <h1 class="text-2xl font-bold tracking-tight text-slate-900 dark:text-slate-100"><%= @contractor.display_name %></h1>
    </div>

    <div class="flex flex-wrap items-center gap-x-5 gap-y-1 text-sm sm:justify-end">
      <% if @contractor.phone.present? %>
        <span class="text-slate-600 dark:text-slate-300"><%= @contractor.phone %></span>
      <% end %>
      <%= contractor_website_link(@contractor, class: "text-brand-600 hover:text-brand-800 dark:text-brand-400 dark:hover:text-brand-300") %>
    </div>

    <% if header_subtitle.present? %>
      <div>
        <p class="text-sm text-slate-500 dark:text-slate-400"><%= header_subtitle %></p>
      </div>
    <% end %>

    <% if @contractor.portfolio_categories.any? %>
      <div class="flex flex-wrap gap-2 sm:justify-end <%= "sm:col-start-2" unless header_subtitle.present? %>">
        <% @contractor.portfolio_categories.each do |category| %>
          <%= status_badge category.titleize, :indigo %>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
<% if @portfolio_items.any? %>
  <div class="space-y-4">
    <% @portfolio_items.group_by(&:category).sort.each do |category, items| %>
      <details class="group rounded-lg border border-slate-200 bg-white shadow-sm dark:border-slate-700 dark:bg-slate-800" open>
        <summary class="flex cursor-pointer list-none items-center justify-between gap-3 p-4 [&::-webkit-details-marker]:hidden">
          <h2 class="text-lg font-semibold text-slate-900 dark:text-slate-100">
            <%= category.titleize %>
            <span class="text-sm font-normal text-slate-500 dark:text-slate-400">(<%= items.size %>)</span>
          </h2>
          <svg class="h-5 w-5 shrink-0 text-slate-400 transition-transform group-open:rotate-180 dark:text-slate-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
          </svg>
        </summary>
        <div class="divide-y divide-slate-200 border-t border-slate-200 px-4 pb-4 dark:divide-slate-700 dark:border-slate-700">
          <% items.each do |item| %>
            <%= render "contractors/portfolio_item", item: item %>
          <% end %>
        </div>
      </details>
    <% end %>
  </div>
<% else %>
  <%= render "shared/empty_state", message: "This contractor has not added portfolio items yet." %>
<% end %>

<p class="mt-6">
  <%= link_to "Back to contractors", contractors_path, class: "text-sm font-medium text-brand-600 hover:text-brand-800 dark:text-brand-400 dark:hover:text-brand-300" %>
</p>
