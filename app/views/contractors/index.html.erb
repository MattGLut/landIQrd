<% content_for :title, "Contractors" %>

<%= render "shared/page_header", title: "Contractors", subtitle: "Browse contractor portfolios and find the right trade for your work." %>

<%= form_with url: contractors_path, method: :get, class: "mb-6 flex flex-wrap items-end gap-3" do %>
  <div>
    <%= label_tag :category, "Filter by trade", class: "block text-xs text-slate-500 dark:text-slate-400" %>
    <%= select_tag :category,
        options_for_select(contractor_category_filter_options, @category_filter),
        class: form_input_class,
        onchange: "this.form.requestSubmit()" %>
  </div>
<% end %>

<% if @contractors.any? %>
  <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    <% @contractors.each do |contractor| %>
      <%= link_to contractor_path(contractor), class: "rounded-xl border border-slate-200 bg-white p-5 shadow-sm transition-colors hover:border-brand-300 dark:border-slate-700 dark:bg-slate-800 dark:hover:border-brand-700" do %>
        <div class="flex items-start gap-3">
          <%= render "shared/user_avatar", user: contractor, size: :md %>
          <div class="min-w-0 flex-1">
            <p class="font-semibold text-slate-900 dark:text-slate-100"><%= contractor.display_name %></p>
            <% if contractor.company_name.present? && contractor.display_name != contractor.company_name %>
              <p class="text-sm text-slate-500 dark:text-slate-400"><%= contractor.company_name %></p>
            <% end %>
            <p class="mt-2 text-sm text-slate-500 dark:text-slate-400">
              <%= pluralize(contractor.contractor_portfolio_items.size, "portfolio item") %>
            </p>
            <% if contractor.website_url.present? %>
              <p class="mt-1 truncate text-sm text-brand-600 dark:text-brand-400"><%= contractor.website_url %></p>
            <% end %>
          </div>
        </div>
      <% end %>
    <% end %>
  </div>
<% else %>
  <%= render "shared/empty_state", message: "No contractors match this filter." %>
<% end %>
