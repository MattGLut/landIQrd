<% content_for :title, "Portfolio" %>

<%= render "shared/page_header",
    title: "Portfolio",
    subtitle: "Showcase your work",
    action: render("shared/button", label: "Add portfolio item", url: new_contractor_portfolio_item_path, variant: :primary) %>

<% if @portfolio_items.any? %>
  <div class="space-y-4">
    <% @portfolio_items.each do |item| %>
      <div class="rounded-lg border border-slate-200 bg-white p-4 shadow-sm dark:border-slate-700 dark:bg-slate-800">
        <div class="flex flex-wrap items-start justify-between gap-3">
          <div class="min-w-0 flex-1">
            <div class="flex flex-wrap items-center gap-2">
              <h2 class="text-lg font-semibold text-slate-900 dark:text-slate-100"><%= item.title %></h2>
              <%= status_badge item.category.titleize, :indigo %>
            </div>
            <% if item.description.present? %>
              <p class="mt-2 text-sm text-slate-600 dark:text-slate-300"><%= item.description %></p>
            <% end %>
          </div>
          <div class="flex shrink-0 flex-wrap items-center gap-2">
            <%= render "shared/button", label: "Edit", url: edit_contractor_portfolio_item_path(item), variant: :secondary, size: :sm %>
            <%= render "shared/button", label: "Delete", url: contractor_portfolio_item_path(item), variant: :danger_link, size: :sm, method: :delete, form: { data: { turbo_confirm: "Remove this portfolio item?" }, class: "inline" } %>
          </div>
        </div>

        <% if item.photos.attached? %>
          <div class="mt-4 grid grid-cols-3 gap-3 sm:grid-cols-4">
            <% item.photos.each do |photo| %>
              <%= link_to rails_blob_path(photo, disposition: "inline"), class: "block overflow-hidden rounded-lg border border-slate-200 dark:border-slate-700" do %>
                <%= portfolio_photo_thumbnail(photo) %>
              <% end %>
            <% end %>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
<% else %>
  <%= render "shared/empty_state",
      message: "No portfolio items yet.",
      action: render("shared/button", label: "Add portfolio item", url: new_contractor_portfolio_item_path, variant: :primary) %>
<% end %>

<p class="mt-6">
  <%= link_to "Back to business profile", edit_contractor_business_profile_path, class: "text-sm font-medium text-brand-600 hover:text-brand-800 dark:text-brand-400 dark:hover:text-brand-300" %>
</p>
