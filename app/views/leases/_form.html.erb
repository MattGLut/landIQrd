<%= form_with model: lease, url: form_url, class: "space-y-4 rounded-lg border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-700 dark:bg-slate-800" do |f| %>
  <%= render "shared/form_errors", resource: lease %>

  <div>
    <%= f.label :tenant_id, "Tenant", class: "block text-sm font-medium text-slate-500 dark:text-slate-400" %>
    <%= f.collection_select :tenant_id, tenants, :id, :full_name, { include_blank: "Select a tenant" }, class: form_input_class %>
  </div>

  <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
    <div>
      <%= f.label :start_date, class: "block text-sm font-medium text-slate-500 dark:text-slate-400" %>
      <%= f.date_field :start_date, class: form_input_class %>
    </div>
    <div>
      <%= f.label :end_date, class: "block text-sm font-medium text-slate-500 dark:text-slate-400" %>
      <%= f.date_field :end_date, class: form_input_class %>
    </div>
  </div>

  <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
    <div>
      <%= f.label :rent_amount, "Monthly rent", class: "block text-sm font-medium text-slate-500 dark:text-slate-400" %>
      <%= f.number_field :rent_amount, step: 0.01, class: form_input_class %>
    </div>
    <div>
      <%= f.label :deposit_amount, "Security deposit", class: "block text-sm font-medium text-slate-500 dark:text-slate-400" %>
      <%= f.number_field :deposit_amount, step: 0.01, class: form_input_class %>
    </div>
  </div>

  <div>
    <%= f.label :status, class: "block text-sm font-medium text-slate-500 dark:text-slate-400" %>
    <%= f.select :status, Lease.statuses.keys.map { |s| [ s.titleize, s ] }, {}, class: form_input_class %>
  </div>

  <div>
    <%= f.label :documents, "Lease documents", class: "block text-sm font-medium text-slate-500 dark:text-slate-400" %>
    <%= f.file_field :documents, multiple: true, class: "#{form_file_input_class} mt-1 block w-full" %>
    <% if lease.documents.attached? %>
      <ul class="mt-2 space-y-1 text-sm text-slate-500 dark:text-slate-400">
        <% lease.documents.each do |doc| %>
          <li><%= doc.filename %></li>
        <% end %>
      </ul>
    <% end %>
  </div>

  <div class="flex gap-2">
    <%= f.submit "Save", class: button_classes(:primary), data: { turbo_submits_with: "Saving…" } %>
    <%= render "shared/button", label: "Cancel", url: cancel_url, variant: :secondary %>
  </div>
<% end %>
