<%= form_with model: lease, url: form_url, class: "space-y-4 rounded-lg border border-border-default bg-surface p-6" do |f| %>
  <%= render "shared/form_errors", resource: lease %>

  <div>
    <%= f.label :tenant_id, "Tenant", class: "block text-sm font-medium text-muted" %>
    <%= f.collection_select :tenant_id, tenants, :id, :full_name, { include_blank: "Select a tenant" }, class: "input-dark" %>
  </div>

  <div class="grid grid-cols-2 gap-4">
    <div>
      <%= f.label :start_date, class: "block text-sm font-medium text-muted" %>
      <%= f.date_field :start_date, class: "input-dark" %>
    </div>
    <div>
      <%= f.label :end_date, class: "block text-sm font-medium text-muted" %>
      <%= f.date_field :end_date, class: "input-dark" %>
    </div>
  </div>

  <div class="grid grid-cols-2 gap-4">
    <div>
      <%= f.label :rent_amount, "Monthly rent", class: "block text-sm font-medium text-muted" %>
      <%= f.number_field :rent_amount, step: 0.01, class: "input-dark" %>
    </div>
    <div>
      <%= f.label :deposit_amount, "Security deposit", class: "block text-sm font-medium text-muted" %>
      <%= f.number_field :deposit_amount, step: 0.01, class: "input-dark" %>
    </div>
  </div>

  <div>
    <%= f.label :status, class: "block text-sm font-medium text-muted" %>
    <%= f.select :status, Lease.statuses.keys.map { |s| [ s.titleize, s ] }, {}, class: "input-dark" %>
  </div>

  <div>
    <%= f.label :documents, "Lease documents", class: "block text-sm font-medium text-muted" %>
    <%= f.file_field :documents, multiple: true, class: "file-input-dark mt-1 block w-full" %>
    <% if lease.documents.attached? %>
      <ul class="mt-2 space-y-1 text-sm text-muted">
        <% lease.documents.each do |doc| %>
          <li><%= doc.filename %></li>
        <% end %>
      </ul>
    <% end %>
  </div>

  <div class="flex gap-2">
    <%= f.submit "Save", class: button_classes(:primary) %>
    <%= render "shared/button", label: "Cancel", url: cancel_url, variant: :secondary %>
  </div>
<% end %>
