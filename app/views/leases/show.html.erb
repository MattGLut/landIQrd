<% content_for :title, "Lease" %>

<% property_crumb = { label: @lease.unit.property.name } %>
<% unit_crumb = { label: @lease.unit.label } %>
<% unless current_user.tenant? %>
  <% property_crumb[:path] = property_path(@lease.unit.property) %>
  <% unit_crumb[:path] = unit_path(@lease.unit) %>
<% end %>

<%= property_breadcrumbs(property_crumb, unit_crumb, { label: "Lease" }) %>

<% header_actions = capture do %>
  <% if current_user.tenant? %>
    <%= button_to "Message landlord", conversations_path, params: { recipient_id: @lease.unit.property.landlord_id }, method: :post, class: button_classes(:secondary, size: :sm), form: { class: "inline" } %>
  <% elsif policy(@lease).update? %>
    <%= button_to "Message tenant", conversations_path, params: { recipient_id: @lease.tenant_id }, method: :post, class: button_classes(:secondary, size: :sm), form: { class: "inline" } %>
  <% end %>
  <% if policy(@lease).update? %>
    <%= render "shared/button", label: "Edit", url: edit_lease_path(@lease), variant: :secondary, size: :sm %>
    <%= render "shared/button", label: "Delete", url: lease_path(@lease), variant: :danger_link, size: :sm, method: :delete, form: { data: { turbo_confirm: "Delete this lease?" }, class: "inline" } %>
  <% end %>
<% end %>

<%= render "shared/page_header", title: "#{@lease.unit.property.name} · #{@lease.unit.label}", subtitle: @lease.unit.property.full_address, action: header_actions %>

<dl class="grid grid-cols-2 gap-4 rounded-lg border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-700 dark:bg-slate-800 sm:grid-cols-4">
  <div>
    <dt class="text-sm text-slate-500 dark:text-slate-400">Status</dt>
    <dd class="mt-1"><%= status_badge @lease.status.titleize, @lease.active? ? :green : :gray %></dd>
  </div>
  <div>
    <dt class="text-sm text-slate-500 dark:text-slate-400">Tenant</dt>
    <dd class="mt-1 font-medium text-slate-900 dark:text-slate-100"><%= @lease.tenant.full_name %></dd>
  </div>
  <div>
    <dt class="text-sm text-slate-500 dark:text-slate-400">Monthly rent</dt>
    <dd class="mt-1 font-medium text-brand-600 dark:text-brand-400"><%= number_to_currency @lease.rent_amount %></dd>
  </div>
  <div>
    <dt class="text-sm text-slate-500 dark:text-slate-400">Deposit</dt>
    <dd class="mt-1 font-medium text-slate-900 dark:text-slate-100"><%= number_to_currency @lease.deposit_amount %></dd>
  </div>
  <div class="col-span-2">
    <dt class="text-sm text-slate-500 dark:text-slate-400">Term</dt>
    <dd class="mt-1 font-medium text-slate-900 dark:text-slate-100"><%= @lease.term_description %></dd>
  </div>
</dl>

<div class="mt-6">
  <h2 class="mb-3 text-lg font-semibold text-slate-900 dark:text-slate-100">Documents</h2>
  <% if @lease.documents.attached? %>
    <ul class="space-y-2">
      <% @lease.documents.each do |doc| %>
        <li class="flex items-center justify-between rounded-lg border border-slate-200 bg-white shadow-sm dark:border-slate-700 dark:bg-slate-800 p-3">
          <span class="text-sm text-slate-900 dark:text-slate-100"><%= doc.filename %></span>
          <%= link_to "Download", rails_blob_path(doc, disposition: "attachment"), class: "text-sm font-medium text-brand-600 dark:text-brand-400 hover:text-brand-700 dark:hover:text-brand-300" %>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p class="text-sm text-slate-500 dark:text-slate-400">No documents attached.</p>
  <% end %>
</div>
