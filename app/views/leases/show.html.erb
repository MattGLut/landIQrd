<% content_for :title, "Lease" %>

<%= property_breadcrumbs(
  { label: @lease.unit.property.name, path: property_path(@lease.unit.property) },
  { label: @lease.unit.label, path: unit_path(@lease.unit) },
  { label: "Lease", path: lease_path(@lease) }
) %>

<% header_actions = capture do %>
  <% if current_user.tenant? %>
    <%= button_to "Message landlord", conversations_path, params: { recipient_id: @lease.unit.property.landlord_id }, method: :post, class: button_classes(:secondary, size: :sm), form: { class: "inline" } %>
  <% elsif policy(@lease).update? %>
    <%= button_to "Message tenant", conversations_path, params: { recipient_id: @lease.tenant_id }, method: :post, class: button_classes(:secondary, size: :sm), form: { class: "inline" } %>
  <% end %>
  <% if policy(@lease).update? %>
    <%= render "shared/button", label: "Edit", url: edit_lease_path(@lease), variant: :secondary, size: :sm %>
    <%= render "shared/button", label: "Delete", url: lease_path(@lease), variant: :danger_link, size: :sm, method: :delete, form: { data: { turbo_confirm: "Delete this lease?" }, class: "inline" } %>
  <% end %>
<% end %>

<%= render "shared/page_header", title: "#{@lease.unit.property.name} · #{@lease.unit.label}", subtitle: @lease.unit.property.full_address, action: header_actions %>

<dl class="grid grid-cols-2 gap-4 rounded-lg border border-border-default bg-surface p-6 sm:grid-cols-4">
  <div>
    <dt class="text-sm text-muted">Status</dt>
    <dd class="mt-1"><%= status_badge @lease.status.titleize, @lease.active? ? :green : :gray %></dd>
  </div>
  <div>
    <dt class="text-sm text-muted">Tenant</dt>
    <dd class="mt-1 font-medium text-primary"><%= @lease.tenant.full_name %></dd>
  </div>
  <div>
    <dt class="text-sm text-muted">Monthly rent</dt>
    <dd class="mt-1 font-medium text-accent"><%= number_to_currency @lease.rent_amount %></dd>
  </div>
  <div>
    <dt class="text-sm text-muted">Deposit</dt>
    <dd class="mt-1 font-medium text-primary"><%= number_to_currency @lease.deposit_amount %></dd>
  </div>
  <div class="col-span-2">
    <dt class="text-sm text-muted">Term</dt>
    <dd class="mt-1 font-medium text-primary"><%= @lease.term_description %></dd>
  </div>
</dl>

<div class="mt-6">
  <h2 class="mb-3 text-lg font-semibold text-primary">Documents</h2>
  <% if @lease.documents.attached? %>
    <ul class="space-y-2">
      <% @lease.documents.each do |doc| %>
        <li class="flex items-center justify-between rounded-lg border border-border-default bg-surface p-3">
          <span class="text-sm text-primary"><%= doc.filename %></span>
          <%= link_to "Download", rails_blob_path(doc, disposition: "attachment"), class: "text-sm font-medium text-accent hover:text-accent-hover" %>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p class="text-sm text-muted">No documents attached.</p>
  <% end %>
</div>
