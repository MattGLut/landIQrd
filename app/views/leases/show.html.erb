<% content_for :title, "Lease" %>

<div class="mb-6 flex items-start justify-between">
  <div>
    <h1 class="text-2xl font-bold"><%= @lease.unit.property.name %> &middot; <%= @lease.unit.label %></h1>
    <p class="text-gray-500"><%= @lease.unit.property.full_address %></p>
  </div>
  <div class="flex gap-2">
    <% if current_user.tenant? %>
      <%= button_to "Message landlord", conversations_path, params: { recipient_id: @lease.unit.property.landlord_id }, method: :post, class: "rounded-md border border-gray-300 px-3 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50" %>
    <% elsif policy(@lease).update? %>
      <%= button_to "Message tenant", conversations_path, params: { recipient_id: @lease.tenant_id }, method: :post, class: "rounded-md border border-gray-300 px-3 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50" %>
    <% end %>
    <% if policy(@lease).update? %>
      <%= link_to "Edit", edit_lease_path(@lease), class: "rounded-md border border-gray-300 px-3 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50" %>
      <%= button_to "Delete", lease_path(@lease), method: :delete, class: "rounded-md border border-red-200 px-3 py-2 text-sm font-medium text-red-600 hover:bg-red-50", form: { data: { turbo_confirm: "Delete this lease?" } } %>
    <% end %>
  </div>
</div>

<dl class="grid grid-cols-2 gap-4 rounded-lg border border-gray-200 bg-white p-6 sm:grid-cols-4">
  <div>
    <dt class="text-sm text-gray-500">Status</dt>
    <dd class="mt-1"><%= status_badge @lease.status.titleize, @lease.active? ? :green : :gray %></dd>
  </div>
  <div>
    <dt class="text-sm text-gray-500">Tenant</dt>
    <dd class="mt-1 font-medium"><%= @lease.tenant.full_name %></dd>
  </div>
  <div>
    <dt class="text-sm text-gray-500">Monthly rent</dt>
    <dd class="mt-1 font-medium"><%= number_to_currency @lease.rent_amount %></dd>
  </div>
  <div>
    <dt class="text-sm text-gray-500">Deposit</dt>
    <dd class="mt-1 font-medium"><%= number_to_currency @lease.deposit_amount %></dd>
  </div>
  <div class="col-span-2">
    <dt class="text-sm text-gray-500">Term</dt>
    <dd class="mt-1 font-medium"><%= @lease.term_description %></dd>
  </div>
</dl>

<div class="mt-6">
  <h2 class="mb-3 text-lg font-semibold">Documents</h2>
  <% if @lease.documents.attached? %>
    <ul class="space-y-2">
      <% @lease.documents.each do |doc| %>
        <li class="flex items-center justify-between rounded-lg border border-gray-200 bg-white p-3">
          <span class="text-sm"><%= doc.filename %></span>
          <%= link_to "Download", rails_blob_path(doc, disposition: "attachment"), class: "text-sm font-medium text-indigo-600 hover:text-indigo-500" %>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p class="text-sm text-gray-500">No documents attached.</p>
  <% end %>
</div>
