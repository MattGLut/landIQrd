<% content_for :title, @work_order.title %>

<% header_actions = capture do %>
  <%= button_to "Open conversation", conversations_path, params: { work_order_id: @work_order.id }, method: :post, class: button_classes(:secondary, size: :sm), form: { class: "inline" } %>
  <% if policy(@work_order).edit_details? %>
    <%= render "shared/button", label: "Edit", url: edit_work_order_path(@work_order), variant: :secondary, size: :sm %>
  <% end %>
  <% if policy(@work_order).destroy? %>
    <%= render "shared/button", label: "Delete", url: work_order_path(@work_order), variant: :danger_link, size: :sm, method: :delete, form: { data: { turbo_confirm: "Delete this work order?" }, class: "inline" } %>
  <% end %>
<% end %>

<div class="mb-6 flex flex-wrap items-start justify-between gap-4">
  <div class="min-w-0">
    <div class="flex flex-wrap items-center gap-3">
      <h1 class="text-2xl font-bold text-primary"><%= @work_order.title %></h1>
      <%= render "work_orders/status_control", work_order: @work_order %>
    </div>
    <p class="mt-1 text-sm text-muted"><%= @work_order.unit.property.name %> · <%= @work_order.unit.label %></p>
  </div>
  <% if header_actions.present? %>
    <div class="flex shrink-0 flex-wrap items-center justify-end gap-2"><%= header_actions %></div>
  <% end %>
</div>

<div class="mb-2 flex flex-wrap items-center gap-2">
  <%= status_badge @work_order.category.titleize, :indigo %>
  <%= status_badge @work_order.priority.titleize, @work_order.priority_color %>
</div>

<% show_closure = @work_order.status_cancelled? && @work_order.closure_reason.present? %>

<div class="rounded-lg border border-border-default bg-surface p-6">
  <div class="<%= show_closure ? "grid gap-6 md:grid-cols-2 md:items-start" : "" %>">
    <div>
      <h2 class="text-sm font-medium text-muted">Description</h2>
      <p class="mt-1 whitespace-pre-line text-primary"><%= @work_order.description.presence || "No description provided." %></p>
      <p class="mt-4 text-xs text-muted">
        Reported by <%= @work_order.created_by.display_name %> on <%= @work_order.created_at.to_fs(:long) %>
      </p>
    </div>

    <% if show_closure %>
      <div>
        <p class="text-sm font-medium text-muted">
          <%= work_order_status_label("cancelled", creator: @work_order.created_by) %> by <%= @work_order.closed_by&.display_name || "Unknown" %>
        </p>
        <p class="mt-1 text-sm text-primary"><%= @work_order.closure_reason %></p>
      </div>
    <% end %>
  </div>
</div>

<% if @work_order.photos.attached? %>
  <div class="mt-6">
    <h2 class="mb-3 text-lg font-semibold text-primary">Photos</h2>
    <div class="grid grid-cols-3 gap-3 sm:grid-cols-4">
      <% @work_order.photos.each do |photo| %>
        <%= link_to rails_blob_path(photo, disposition: "inline"), class: "block overflow-hidden rounded-lg border border-border-default" do %>
          <%= image_tag photo.variable? ? photo.variant(resize_to_limit: [ 300, 300 ]) : photo, class: "h-32 w-full object-cover" %>
        <% end %>
      <% end %>
    </div>
  </div>
<% end %>

<div class="mt-6">
  <h2 class="mb-3 text-lg font-semibold text-primary">Contractor assignments</h2>

  <% if @work_order.work_order_assignments.any? %>
    <div class="space-y-2">
      <% @work_order.work_order_assignments.includes(:contractor).each do |assignment| %>
        <div class="flex flex-wrap items-center justify-between gap-3 rounded-lg border border-border-default bg-surface p-4">
          <div>
            <p class="font-medium text-primary"><%= assignment.contractor.display_name %></p>
            <p class="text-sm text-muted">
              <%= assignment.scheduled_at ? "Scheduled #{assignment.scheduled_at.to_fs(:long)}" : "Not scheduled" %>
            </p>
          </div>
          <div class="flex items-center gap-3">
            <%= status_badge assignment.status.titleize, assignment.status_completed? ? :green : :gray %>

            <% if assignment.contractor_id == current_user.id %>
              <%= form_with model: [ @work_order, assignment ], method: :patch, class: "flex items-center gap-2" do |f| %>
                <%= f.select :status, WorkOrderAssignment.statuses.keys.map { |s| [ s.titleize, s ] }, {}, class: "input-dark py-1" %>
                <%= f.submit "Update", class: button_classes(:primary, size: :sm) %>
              <% end %>
            <% end %>

            <% if policy(@work_order).assign? %>
              <%= button_to "Remove", work_order_work_order_assignment_path(@work_order, assignment), method: :delete, class: "text-sm text-danger hover:text-danger/80" %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="text-sm text-muted">No contractors assigned yet.</p>
  <% end %>

  <% if policy(@work_order).assign? %>
    <div class="mt-4 rounded-lg border border-border-default bg-surface p-4">
      <h3 class="mb-2 text-sm font-medium text-muted">Assign a contractor</h3>
      <%= form_with url: work_order_work_order_assignments_path(@work_order), scope: :work_order_assignment, method: :post, class: "flex flex-wrap items-end gap-3" do |f| %>
        <div>
          <%= f.label :contractor_id, "Contractor", class: "block text-xs text-muted" %>
          <%= f.collection_select :contractor_id, @contractors, :id, :display_name, { include_blank: "Select" }, class: "input-dark py-2" %>
        </div>
        <div>
          <%= f.label :scheduled_at, "Scheduled", class: "block text-xs text-muted" %>
          <%= f.datetime_field :scheduled_at, class: "input-dark py-2" %>
        </div>
        <%= f.submit "Assign", class: button_classes(:primary) %>
      <% end %>
    </div>
  <% end %>
</div>

<% if @events.any? %>
  <div class="mt-6">
    <details class="group" open>
      <summary class="mb-3 flex cursor-pointer list-none items-center gap-2 text-lg font-semibold text-primary [&::-webkit-details-marker]:hidden">
        Activity
        <span class="text-sm font-normal text-muted">(<%= @events.size %>)</span>
        <svg class="ml-auto h-5 w-5 shrink-0 text-muted transition-transform group-open:rotate-180"
             xmlns="http://www.w3.org/2000/svg"
             viewBox="0 0 20 20"
             fill="currentColor"
             aria-hidden="true">
          <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 10.94l3.71-3.71a.75.75 0 111.06 1.06l-4.24 4.25a.75.75 0 01-1.06 0L5.21 8.29a.75.75 0 01.02-1.08z" clip-rule="evenodd" />
        </svg>
      </summary>
      <div class="space-y-2">
        <% @events.each do |event| %>
          <div class="rounded-lg border border-border-default bg-surface p-4">
            <p class="text-sm text-primary"><%= event.description %></p>
            <p class="mt-1 text-xs text-muted"><%= event.created_at.to_fs(:long) %></p>
          </div>
        <% end %>
      </div>
    </details>
  </div>
<% end %>
