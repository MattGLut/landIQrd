<% content_for :title, work_orders_nav_label %>

<%= render "shared/page_header", title: work_orders_nav_label, action: (current_user.tenant? || current_user.landlord?) ? render("shared/button", label: "New work request", url: new_work_order_path, variant: :primary) : nil %>

<div class="mb-4 flex flex-wrap gap-2">
  <% [
    [ "All", nil ],
    [ "Active", "active" ],
    [ "Completed", "completed" ],
    [ "Cancelled", "cancelled" ]
  ].each do |label, value| %>
    <% active = @status_filter == value || (value.nil? && @status_filter.blank?) %>
    <%= link_to label, work_orders_path(status: value), class: "rounded-full px-3 py-1 text-sm font-medium #{active ? 'bg-accent/15 text-accent' : 'bg-elevated text-muted hover:text-primary'}" %>
  <% end %>
</div>

<% if @work_orders.any? %>
  <div class="space-y-2">
    <%= render @work_orders %>
  </div>
<% else %>
  <%= render "shared/empty_state", message: "No work orders yet." %>
<% end %>
