<% content_for :title, "Work orders" %>

<div class="mb-6 flex items-center justify-between">
  <h1 class="text-2xl font-bold">Work orders</h1>
  <% if current_user.tenant? || current_user.landlord? %>
    <%= link_to "New work request", new_work_order_path, class: "rounded-md bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-500" %>
  <% end %>
</div>

<% if @work_orders.any? %>
  <div class="space-y-2">
    <%= render @work_orders %>
  </div>
<% else %>
  <div class="rounded-lg border border-dashed border-gray-300 bg-white p-10 text-center text-gray-500">
    No work orders yet.
  </div>
<% end %>
