<% content_for :title, work_orders_nav_label %>

<%= render "shared/page_header", title: work_orders_nav_label, action: (current_user.tenant? || current_user.landlord?) ? render("shared/button", label: "New work request", url: new_work_order_path, variant: :primary) : nil %>

<div class="mb-4 flex flex-wrap gap-2">
  <% [
    [ "All", nil ],
    [ "Active", "active" ],
    [ "Completed", "completed" ],
    [ "Cancelled", "cancelled" ]
  ].each do |label, value| %>
    <% active = @status_filter == value || (value.nil? && @status_filter.blank?) %>
    <%= link_to label, work_orders_path(status: value), class: "rounded-full px-3 py-1 text-sm font-medium #{active ? 'bg-brand-50 dark:bg-brand-900/30 text-brand-600 dark:text-brand-400' : 'bg-slate-50 dark:bg-slate-700 text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-100'}" %>
  <% end %>
</div>

<% if @work_orders.any? %>
  <div class="space-y-2">
    <%= render @work_orders %>
  </div>
<% else %>
  <% empty_action = (current_user.tenant? || current_user.landlord?) ? render("shared/button", label: "New work request", url: new_work_order_path, variant: :primary) : nil %>
  <%= render "shared/empty_state", message: "No work orders yet.", action: empty_action %>
<% end %>
