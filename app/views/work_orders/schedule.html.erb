<% content_for :title, "Schedule" %>

<%= render "shared/page_header", title: "Schedule", subtitle: "Upcoming contractor visits" %>

<% if @assignments.any? %>
  <div class="space-y-2">
    <% @assignments.each do |assignment| %>
      <div class="rounded-lg border border-slate-200 bg-white p-4 shadow-sm dark:border-slate-700 dark:bg-slate-800">
        <div class="flex flex-wrap items-start justify-between gap-3">
          <div>
            <p class="font-medium text-slate-900 dark:text-slate-100"><%= assignment.work_order.title %></p>
            <p class="text-sm text-slate-500 dark:text-slate-400"><%= assignment.work_order.unit.property.name %> · <%= assignment.work_order.unit.label %></p>
            <p class="mt-1 text-sm text-slate-900 dark:text-slate-100"><%= assignment.contractor.display_name %></p>
          </div>
          <div class="text-right">
            <p class="text-sm font-medium text-brand-600 dark:text-brand-400"><%= assignment.scheduled_at.to_fs(:long) %></p>
            <%= link_to "View", work_order_path(assignment.work_order), class: "text-sm text-slate-500 dark:text-slate-400 hover:text-brand-600 dark:hover:text-brand-400" %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <%= render "shared/empty_state", message: "No scheduled visits yet." %>
<% end %>
