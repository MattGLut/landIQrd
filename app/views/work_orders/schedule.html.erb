<% content_for :title, "Schedule" %>

<%= render "shared/page_header", title: "Schedule", subtitle: "Upcoming contractor visits" %>

<% if @assignments.any? %>
  <div class="space-y-2">
    <% @assignments.each do |assignment| %>
      <div class="rounded-lg border border-border-default bg-surface p-4">
        <div class="flex flex-wrap items-start justify-between gap-3">
          <div>
            <p class="font-medium text-primary"><%= assignment.work_order.title %></p>
            <p class="text-sm text-muted"><%= assignment.work_order.unit.property.name %> · <%= assignment.work_order.unit.label %></p>
            <p class="mt-1 text-sm text-primary"><%= assignment.contractor.display_name %></p>
          </div>
          <div class="text-right">
            <p class="text-sm font-medium text-accent"><%= assignment.scheduled_at.to_fs(:long) %></p>
            <%= link_to "View", work_order_path(assignment.work_order), class: "text-sm text-muted hover:text-accent" %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <%= render "shared/empty_state", message: "No scheduled visits yet." %>
<% end %>
