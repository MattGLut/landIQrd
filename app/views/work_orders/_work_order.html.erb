<%= link_to work_order_path(work_order), class: "flex items-center justify-between rounded-lg border border-slate-200 bg-white p-4 shadow-sm dark:border-slate-700 dark:bg-slate-800 transition-colors hover:border-brand-300 dark:hover:border-brand-700" do %>
  <div>
    <p class="font-medium text-slate-900 dark:text-slate-100"><%= work_order.title %></p>
    <p class="text-sm text-slate-500 dark:text-slate-400"><%= work_order.unit.property.name %> · <%= work_order.unit.label %></p>
  </div>
  <div class="flex items-center gap-2">
    <%= status_badge work_order.priority.titleize, work_order.priority_color %>
    <%= status_badge work_order.status.titleize.gsub("_", " "), work_order.status_color %>
  </div>
<% end %>
