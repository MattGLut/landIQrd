<%= link_to work_order_path(work_order), class: "flex items-center justify-between rounded-lg border border-border-default bg-surface p-4 transition-colors hover:border-accent/50" do %>
  <div>
    <p class="font-medium text-primary"><%= work_order.title %></p>
    <p class="text-sm text-muted"><%= work_order.unit.property.name %> · <%= work_order.unit.label %></p>
  </div>
  <div class="flex items-center gap-2">
    <%= status_badge work_order.priority.titleize, work_order.priority_color %>
    <%= status_badge work_order.status.titleize.gsub("_", " "), work_order.status_color %>
  </div>
<% end %>
