<% unit_types = units.index_with { |unit| unit.effective_type }.transform_keys(&:id) %>
<% form_data = work_order.persisted? ? {} : { controller: "work-order-category", work_order_category_unit_types_value: unit_types.to_json } %>
<%= form_with model: work_order, url: form_url, class: "space-y-4 rounded-lg border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-700 dark:bg-slate-800", data: form_data do |f| %>
  <%= render "shared/form_errors", resource: work_order %>

  <% unless work_order.persisted? %>
    <div>
      <%= f.label :unit_id, "Unit", class: "block text-sm font-medium text-slate-500 dark:text-slate-400" %>
      <%= f.collection_select :unit_id, units, :id, :full_label, { include_blank: "Select a unit" }, class: form_input_class, data: { work_order_category_target: "unitSelect" } %>
    </div>
  <% end %>

  <div>
    <%= f.label :title, class: "block text-sm font-medium text-slate-500 dark:text-slate-400" %>
    <%= f.text_field :title, class: form_input_class %>
  </div>

  <div>
    <%= f.label :description, class: "block text-sm font-medium text-slate-500 dark:text-slate-400" %>
    <%= f.text_area :description, rows: 4, class: form_input_class %>
  </div>

  <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
    <div>
      <%= f.label :category, class: "block text-sm font-medium text-slate-500 dark:text-slate-400" %>
      <% if work_order.persisted? %>
        <%= f.select :category, WorkOrder.category_options_for(work_order.unit), {}, class: form_input_class %>
      <% else %>
        <%= f.select :category, WorkOrder.categories.keys.map { |c| [ c.titleize, c ] }, {}, class: form_input_class, data: { work_order_category_target: "categorySelect" } %>
      <% end %>
    </div>
    <div>
      <%= f.label :priority, class: "block text-sm font-medium text-slate-500 dark:text-slate-400" %>
      <%= f.select :priority, WorkOrder.priorities.keys.map { |p| [ p.titleize, p ] }, {}, class: form_input_class %>
    </div>
  </div>

  <div>
    <%= f.label :photos, class: "block text-sm font-medium text-slate-500 dark:text-slate-400" %>
    <% if work_order.photos.attached? %>
      <div class="mb-3 grid grid-cols-3 gap-3 sm:grid-cols-4">
        <% work_order.photos.each do |photo| %>
          <%= link_to rails_blob_path(photo, disposition: "inline"), class: "block overflow-hidden rounded-lg border border-slate-200 dark:border-slate-700" do %>
            <%= work_order_photo_thumbnail(photo) %>
          <% end %>
        <% end %>
      </div>
    <% end %>
    <%= f.file_field :photos, multiple: true, accept: "image/*", class: "#{form_file_input_class} mt-1 block w-full" %>
  </div>

  <div class="flex gap-2">
    <%= f.submit "Save", class: button_classes(:primary), data: { turbo_submits_with: "Saving…" } %>
    <%= render "shared/button", label: "Cancel", url: cancel_url, variant: :secondary %>
  </div>
<% end %>
