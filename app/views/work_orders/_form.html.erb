<%= form_with model: work_order, url: form_url, class: "space-y-4 rounded-lg border border-border-default bg-surface p-6" do |f| %>
  <%= render "shared/form_errors", resource: work_order %>

  <% unless work_order.persisted? %>
    <div>
      <%= f.label :unit_id, "Unit", class: "block text-sm font-medium text-muted" %>
      <%= f.collection_select :unit_id, units, :id, :full_label, { include_blank: "Select a unit" }, class: "input-dark" %>
    </div>
  <% end %>

  <div>
    <%= f.label :title, class: "block text-sm font-medium text-muted" %>
    <%= f.text_field :title, class: "input-dark" %>
  </div>

  <div>
    <%= f.label :description, class: "block text-sm font-medium text-muted" %>
    <%= f.text_area :description, rows: 4, class: "input-dark" %>
  </div>

  <div class="grid grid-cols-2 gap-4">
    <div>
      <%= f.label :category, class: "block text-sm font-medium text-muted" %>
      <%= f.select :category, WorkOrder.categories.keys.map { |c| [ c.titleize, c ] }, {}, class: "input-dark" %>
    </div>
    <div>
      <%= f.label :priority, class: "block text-sm font-medium text-muted" %>
      <%= f.select :priority, WorkOrder.priorities.keys.map { |p| [ p.titleize, p ] }, {}, class: "input-dark" %>
    </div>
  </div>

  <div>
    <%= f.label :photos, class: "block text-sm font-medium text-muted" %>
    <%= f.file_field :photos, multiple: true, accept: "image/*", class: "file-input-dark mt-1 block w-full" %>
  </div>

  <div class="flex gap-2">
    <%= f.submit "Save", class: button_classes(:primary) %>
    <%= render "shared/button", label: "Cancel", url: cancel_url, variant: :secondary %>
  </div>
<% end %>
