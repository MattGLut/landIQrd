<div class="mt-4 rounded-lg border border-slate-200 bg-white p-4 shadow-sm dark:border-slate-700 dark:bg-slate-800">
  <div class="mb-4 flex flex-wrap items-center justify-between gap-3">
    <h3 class="text-sm font-medium text-slate-500 dark:text-slate-400">Assign a contractor</h3>
    <div class="flex gap-2 text-sm">
      <%= link_to "Show all",
          work_order_path(work_order, contractor_filter: "all"),
          class: contractor_filter == "all" ? "font-medium text-brand-600 dark:text-brand-400" : "text-slate-500 hover:text-slate-900 dark:text-slate-400 dark:hover:text-slate-100" %>
      <span class="text-slate-300 dark:text-slate-600">|</span>
      <%= link_to "Relevant only",
          work_order_path(work_order, contractor_filter: "relevant"),
          class: contractor_filter == "relevant" ? "font-medium text-brand-600 dark:text-brand-400" : "text-slate-500 hover:text-slate-900 dark:text-slate-400 dark:hover:text-slate-100" %>
    </div>
  </div>

  <% if contractors.any? %>
    <div class="space-y-3">
      <% contractors.each do |contractor| %>
        <% relevant_count = contractor.relevant_portfolio_items_for(work_order.category).count %>
        <div class="rounded-lg border border-slate-200 p-4 dark:border-slate-700" data-contractor-picker-row>
          <div class="flex flex-wrap items-start justify-between gap-3">
            <div class="flex min-w-0 items-start gap-3">
              <%= render "shared/user_avatar", user: contractor, size: :sm %>
              <div>
                <p class="font-medium text-slate-900 dark:text-slate-100"><%= contractor.display_name %></p>
                <% if contractor.company_name.present? && contractor.display_name != contractor.company_name %>
                  <p class="text-sm text-slate-500 dark:text-slate-400"><%= contractor.company_name %></p>
                <% end %>
                <div class="mt-1 flex flex-wrap items-center gap-2">
                  <% if relevant_count.positive? %>
                    <%= status_badge(relevant_count == 1 ? "1 relevant project" : "#{relevant_count} relevant projects", :green) %>
                  <% end %>
                  <%= link_to "View portfolio", contractor_path(contractor), class: "text-sm font-medium text-brand-600 hover:text-brand-800 dark:text-brand-400 dark:hover:text-brand-300" %>
                </div>
              </div>
            </div>

            <%= form_with url: work_order_work_order_assignments_path(work_order), scope: :work_order_assignment, method: :post, class: "flex flex-wrap items-end gap-2" do |f| %>
              <%= f.hidden_field :contractor_id, value: contractor.id %>
              <div>
                <%= f.label :scheduled_at, "Scheduled", class: "block text-xs text-slate-500 dark:text-slate-400" %>
                <%= f.datetime_field :scheduled_at, class: "#{form_input_class} py-1.5" %>
              </div>
              <%= f.submit "Assign", class: button_classes(:primary, size: :sm), data: { turbo_submits_with: "Assigning…" } %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="text-sm text-slate-500 dark:text-slate-400">No contractors match this filter.</p>
  <% end %>
</div>
