<div class="grid gap-4 sm:grid-cols-3">
  <%= link_to admin_users_path, class: "rounded-lg border border-border-default bg-surface p-5 transition-colors hover:border-accent/50" do %>
    <p class="text-sm text-muted">Users</p>
    <p class="mt-1 text-3xl font-bold text-primary"><%= @users_count %></p>
  <% end %>
  <%= link_to admin_properties_path, class: "rounded-lg border border-border-default bg-surface p-5 transition-colors hover:border-accent/50" do %>
    <p class="text-sm text-muted">Properties</p>
    <p class="mt-1 text-3xl font-bold text-primary"><%= @properties_count %></p>
  <% end %>
  <%= link_to admin_work_orders_path, class: "rounded-lg border border-border-default bg-surface p-5 transition-colors hover:border-accent/50" do %>
    <p class="text-sm text-muted">Work orders</p>
    <p class="mt-1 text-3xl font-bold text-accent"><%= @work_orders_count %></p>
  <% end %>
</div>

<div class="mt-6">
  <%= render "shared/button", label: "Open admin console", url: admin_dashboard_path, variant: :primary %>
</div>
