<div class="<%= panel_card_class %>">
  <div class="flex items-center justify-between gap-4">
    <h2 class="text-lg font-semibold text-slate-900 dark:text-slate-100">Properties</h2>
    <%= link_to "View all", properties_path, class: "text-sm font-medium text-brand-600 hover:text-brand-800 dark:text-brand-400 dark:hover:text-brand-300" %>
  </div>
  <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">
    <%= pluralize(@properties_count, "property") %> in your portfolio.
  </p>

  <% if @recent_properties.any? %>
    <ul class="mt-4 space-y-3">
      <% @recent_properties.each do |property| %>
        <li>
          <%= link_to property_path(property), class: dashboard_list_link_class do %>
            <div class="flex flex-wrap items-baseline justify-between gap-2">
              <span class="font-medium text-slate-900 line-clamp-1 dark:text-slate-100"><%= property.name %></span>
              <span class="text-xs text-slate-500 dark:text-slate-400"><%= pluralize(property.units.size, "unit") %></span>
            </div>
            <% if property.full_address.present? %>
              <p class="mt-0.5 text-xs text-slate-500 line-clamp-1 dark:text-slate-400"><%= property.full_address %></p>
            <% end %>
          <% end %>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p class="mt-4 text-sm text-slate-500 dark:text-slate-400">No properties yet.</p>
    <p class="mt-3">
      <%= link_to "Add property", new_property_path, class: "text-sm font-medium text-brand-600 hover:text-brand-800 dark:text-brand-400 dark:hover:text-brand-300" %>
    </p>
  <% end %>
</div>
