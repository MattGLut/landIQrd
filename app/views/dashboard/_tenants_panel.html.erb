<div class="<%= panel_card_class %>">
  <h2 class="text-lg font-semibold text-slate-900 dark:text-slate-100">Tenants</h2>
  <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">
    <%= pluralize(@tenants_count, "active tenant") %> across your properties.
  </p>

  <% if @recent_tenant_leases.any? %>
    <ul class="mt-4 space-y-3">
      <% @recent_tenant_leases.each do |lease| %>
        <li>
          <%= link_to lease_path(lease), class: dashboard_list_link_class do %>
            <div class="flex flex-wrap items-baseline justify-between gap-2">
              <span class="font-medium text-slate-900 line-clamp-1 dark:text-slate-100"><%= lease.tenant.full_name %></span>
              <span class="text-xs text-slate-500 dark:text-slate-400"><%= number_to_currency lease.rent_amount %>/mo</span>
            </div>
            <p class="mt-0.5 text-xs text-slate-500 line-clamp-1 dark:text-slate-400">
              <%= lease.unit.property.name %> &middot; <%= lease.unit.label %>
            </p>
          <% end %>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p class="mt-4 text-sm text-slate-500 dark:text-slate-400">No active tenants yet.</p>
    <p class="mt-3">
      <%= link_to "View properties", properties_path, class: "text-sm font-medium text-brand-600 hover:text-brand-800 dark:text-brand-400 dark:hover:text-brand-300" %>
    </p>
  <% end %>
</div>
