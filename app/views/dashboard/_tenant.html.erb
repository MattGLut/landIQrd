<div class="grid gap-4 sm:grid-cols-3">
  <div class="rounded-lg border border-border-default bg-surface p-5">
    <p class="text-sm text-muted">Active leases</p>
    <p class="mt-1 text-3xl font-bold text-primary"><%= @leases&.count.to_i %></p>
  </div>
  <%= link_to work_orders_path(status: "active"), class: "rounded-lg border border-border-default bg-surface p-5 transition-colors hover:border-accent/50" do %>
    <p class="text-sm text-muted">My work requests</p>
    <p class="mt-1 text-3xl font-bold text-accent"><%= @open_work_orders_count %></p>
  <% end %>
  <%= link_to conversations_path, class: "rounded-lg border border-border-default bg-surface p-5 transition-colors hover:border-accent/50" do %>
    <p class="text-sm text-muted">Conversations</p>
    <p class="mt-1 text-3xl font-bold text-primary"><%= @conversations_count %></p>
  <% end %>
</div>

<% if @leases.present? %>
  <div class="mt-6 space-y-3">
    <h2 class="text-lg font-semibold text-primary">Your leases</h2>
    <% @leases.each do |lease| %>
      <%= link_to lease_path(lease), class: "block rounded-lg border border-border-default bg-surface p-4 transition-colors hover:border-accent/50" do %>
        <p class="font-medium text-primary"><%= lease.unit.property.name %> · <%= lease.unit.label %></p>
        <p class="text-sm text-muted"><%= lease.term_description %></p>
      <% end %>
    <% end %>
  </div>
<% end %>

<% if @expiring_soon_lease %>
  <div class="mt-6 rounded-lg border border-yellow-500/30 bg-yellow-500/10 p-4">
    <p class="text-sm font-medium text-yellow-400">Lease ending soon</p>
    <p class="mt-1 text-primary"><%= @expiring_soon_lease.unit.property.name %> · <%= @expiring_soon_lease.unit.label %> ends <%= @expiring_soon_lease.end_date.to_fs(:long) %></p>
    <%= link_to "View lease", lease_path(@expiring_soon_lease), class: "mt-2 inline-block text-sm text-accent hover:text-accent-hover" %>
  </div>
<% end %>

<div class="mt-6">
  <%= render "shared/button", label: "New work request", url: new_work_order_path, variant: :primary %>
</div>
