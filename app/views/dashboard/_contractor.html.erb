<div class="grid gap-4 sm:grid-cols-2">
  <%= link_to work_orders_path, class: "rounded-lg border border-gray-200 bg-white p-5 hover:border-indigo-300" do %>
    <p class="text-sm text-gray-500">Assigned work orders</p>
    <p class="mt-1 text-2xl font-semibold"><%= @assigned_work_orders_count %></p>
  <% end %>
  <%= link_to conversations_path, class: "rounded-lg border border-gray-200 bg-white p-5 hover:border-indigo-300" do %>
    <p class="text-sm text-gray-500">Conversations</p>
    <p class="mt-1 text-2xl font-semibold"><%= @conversations_count %></p>
  <% end %>
</div>

<div class="mt-6">
  <%= link_to "View assigned work", work_orders_path, class: "inline-flex rounded-md bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-500" %>
</div>
