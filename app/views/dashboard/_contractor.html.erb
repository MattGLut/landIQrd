<div class="grid gap-4 sm:grid-cols-2">
  <%= link_to work_orders_path, class: "rounded-lg border border-border-default bg-surface p-5 transition-colors hover:border-accent/50" do %>
    <p class="text-sm text-muted">Assigned work orders</p>
    <p class="mt-1 text-3xl font-bold text-accent"><%= @assigned_work_orders_count %></p>
  <% end %>
  <%= link_to conversations_path, class: "rounded-lg border border-border-default bg-surface p-5 transition-colors hover:border-accent/50" do %>
    <p class="text-sm text-muted">Conversations</p>
    <p class="mt-1 text-3xl font-bold text-primary"><%= @conversations_count %></p>
  <% end %>
</div>

<div class="mt-6">
  <%= render "shared/button", label: "View assigned work", url: work_orders_path, variant: :primary %>
</div>
