<div class="<%= panel_card_class %>">
  <div class="flex flex-wrap items-baseline justify-between gap-2">
    <h2 class="text-lg font-semibold text-slate-900 dark:text-slate-100">Conversations</h2>
    <% if @unread_conversations_count.to_i.positive? %>
      <span class="rounded-full bg-brand-50 px-2.5 py-0.5 text-sm font-medium text-brand-800 dark:bg-brand-900/30 dark:text-brand-300">
        <%= @unread_conversations_count %> unread
      </span>
    <% end %>
  </div>
  <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">Recent messages.</p>

  <% if @recent_conversations.any? %>
    <ul class="mt-4 space-y-3">
      <% @recent_conversations.each do |conversation| %>
        <% unread = conversation.unread_for?(current_user) %>
        <li>
          <%= link_to conversation_path(conversation), class: dashboard_list_link_class do %>
            <div class="flex flex-wrap items-baseline justify-between gap-2">
              <span class="font-medium line-clamp-1 <%= unread ? 'text-slate-900 dark:text-slate-100' : 'text-slate-700 dark:text-slate-200' %>">
                <%= conversation.title %>
              </span>
              <% if unread %>
                <span class="h-2 w-2 shrink-0 rounded-full bg-brand-600"></span>
              <% end %>
            </div>
            <p class="mt-0.5 text-xs text-slate-500 line-clamp-1 dark:text-slate-400">
              <% preview = conversation.latest_message&.body.presence %>
              <%= preview || "No messages yet" %>
            </p>
            <p class="mt-0.5 text-xs text-slate-500 dark:text-slate-400">
              <%= conversation.participants.reject { |u| u.id == current_user.id }.map(&:display_name).join(", ").presence || "No other participants" %>
            </p>
          <% end %>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p class="mt-4 text-sm text-slate-500 dark:text-slate-400">No conversations yet.</p>
  <% end %>

  <p class="mt-4">
    <%= link_to "View all messages", conversations_path, class: "text-sm font-medium text-brand-600 hover:text-brand-800 dark:text-brand-400 dark:hover:text-brand-300" %>
  </p>
</div>
