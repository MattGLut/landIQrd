<% size = local_assigns.fetch(:size, :md) %>
<% sizes = { sm: "h-8 w-8 text-xs", md: "h-9 w-9 text-sm", lg: "h-12 w-12 text-base" } %>
<% classes = "inline-flex shrink-0 items-center justify-center overflow-hidden rounded-full bg-accent/20 font-medium text-accent #{sizes.fetch(size)}" %>

<% if user.avatar.attached? %>
  <%= image_tag user.avatar.variant(resize_to_fill: [ 96, 96 ]), class: "#{classes} object-cover", alt: user.display_name %>
<% else %>
  <span class="<%= classes %>"><%= user.initials %></span>
<% end %>
