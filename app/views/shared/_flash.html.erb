<% flash.each do |type, message| %>
  <% next if message.blank? %>
  <% style = type.to_sym == :alert ? "border-danger/30 bg-danger/10 text-danger" : "border-accent/30 bg-accent/10 text-accent" %>
  <div class="mb-4 rounded-lg border px-4 py-3 text-sm <%= style %>" role="alert">
    <%= message %>
  </div>
<% end %>
