<header class="flex h-14 shrink-0 items-center justify-between border-b border-border-default bg-base px-4 lg:px-6">
  <div class="flex items-center gap-3">
    <button type="button"
            data-action="sidebar#toggle"
            class="rounded-md p-2 text-muted hover:bg-elevated hover:text-primary lg:hidden"
            aria-label="Open menu">
      <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"/>
      </svg>
    </button>
    <% if content_for?(:title) %>
      <h2 class="text-sm font-medium text-muted lg:hidden"><%= content_for(:title) %></h2>
    <% end %>
  </div>

  <div class="flex items-center gap-4 text-sm">
    <%= link_to edit_account_path, class: "flex items-center gap-2 text-muted hover:text-primary" do %>
      <%= render "shared/user_avatar", user: current_user, size: :sm %>
      <span class="hidden text-muted sm:inline"><%= current_user.display_name %></span>
    <% end %>
    <%= button_to "Sign out", destroy_user_session_path, method: :delete, class: "text-muted hover:text-primary" %>
  </div>
</header>
