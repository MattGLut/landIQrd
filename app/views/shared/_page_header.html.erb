<div class="mb-6 flex flex-wrap items-start justify-between gap-4">
  <div>
    <h1 class="text-2xl font-bold tracking-tight text-slate-900 dark:text-slate-100"><%= title %></h1>
    <% if local_assigns[:subtitle].present? %>
      <p class="mt-1 text-sm text-slate-500 dark:text-slate-400"><%= subtitle %></p>
    <% end %>
  </div>
  <% if local_assigns[:action].present? %>
    <div class="flex shrink-0 flex-wrap items-center justify-end gap-2"><%= action %></div>
  <% end %>
</div>
